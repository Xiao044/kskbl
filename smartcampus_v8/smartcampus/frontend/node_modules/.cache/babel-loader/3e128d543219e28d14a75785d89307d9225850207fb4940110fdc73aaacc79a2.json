{"ast":null,"code":"import { ref, watch, computed } from 'vue';\nimport AnimatedCharacters from './AnimatedCharacters.vue';\nimport zhCN from '../i18n/zh-CN';\nimport enUS from '../i18n/en-US';\nimport i18n from '../i18n';\nexport default {\n  __name: 'LoginView',\n  emits: ['login-success'],\n  setup(__props, {\n    expose: __expose,\n    emit: __emit\n  }) {\n    __expose();\n    const lang = ref('zh-CN');\n    const dict = computed(() => lang.value === 'zh-CN' ? zhCN : enUS);\n    function t(key) {\n      const row = dict.value;\n      return row[key] ?? key;\n    }\n    const langLabel = computed(() => lang.value === 'zh-CN' ? 'English' : '中文');\n    function toggleLocale() {\n      lang.value = lang.value === 'zh-CN' ? 'en-US' : 'zh-CN';\n      i18n.global.locale.value = lang.value;\n    }\n    const emit = __emit;\n    const username = ref('');\n    const password = ref('');\n    const rememberMe = ref(false);\n    const showPassword = ref(false);\n    const focusedField = ref('none');\n    const isLoginError = ref(false);\n    const isTyping = ref(false);\n    const loading = ref(false);\n    const formBanner = ref('');\n    let errorTimer = null;\n    const characterConfig = {\n      scale: 0.88,\n      mouseSensitivityX: 20,\n      mouseSensitivityY: 30,\n      pupilFollowFactor: 0.35\n    };\n    function onUsernameFocus() {\n      focusedField.value = 'email';\n      isTyping.value = true;\n    }\n    function onUsernameBlur() {\n      focusedField.value = 'none';\n      isTyping.value = false;\n    }\n    function onPasswordFocus() {\n      focusedField.value = 'password';\n      isTyping.value = true;\n    }\n    function onPasswordBlur() {\n      focusedField.value = 'none';\n      isTyping.value = false;\n    }\n    function togglePassword() {\n      showPassword.value = !showPassword.value;\n    }\n    function clearFormErrors() {\n      formBanner.value = '';\n    }\n    async function handleLogin() {\n      clearFormErrors();\n      if (!username.value.trim() || !password.value) {\n        formBanner.value = t('loginFailEmpty');\n        triggerError();\n        return;\n      }\n      loading.value = true;\n\n      // Mock 本地静态验证（纯前端调试阶段，暂不调用后端接口）\n      await new Promise(r => setTimeout(r, 600)); // 模拟网络延迟，保留加载态体验\n      if (username.value === 'admin' && password.value === '123456') {\n        localStorage.setItem('token', 'mock-local-token-12345');\n        emit('login-success');\n      } else {\n        formBanner.value = t('loginFailCheck');\n        triggerError();\n      }\n      loading.value = false;\n    }\n    function triggerError() {\n      isLoginError.value = true;\n      if (errorTimer) window.clearTimeout(errorTimer);\n      errorTimer = window.setTimeout(() => {\n        isLoginError.value = false;\n      }, 2200);\n    }\n    watch([username, password], () => {\n      clearFormErrors();\n      if (isLoginError.value) {\n        isLoginError.value = false;\n        if (errorTimer) {\n          window.clearTimeout(errorTimer);\n          errorTimer = null;\n        }\n      }\n    });\n    const __returned__ = {\n      lang,\n      dict,\n      t,\n      langLabel,\n      toggleLocale,\n      emit,\n      username,\n      password,\n      rememberMe,\n      showPassword,\n      focusedField,\n      isLoginError,\n      isTyping,\n      loading,\n      formBanner,\n      get errorTimer() {\n        return errorTimer;\n      },\n      set errorTimer(v) {\n        errorTimer = v;\n      },\n      characterConfig,\n      onUsernameFocus,\n      onUsernameBlur,\n      onPasswordFocus,\n      onPasswordBlur,\n      togglePassword,\n      clearFormErrors,\n      handleLogin,\n      triggerError,\n      ref,\n      watch,\n      computed,\n      AnimatedCharacters,\n      get zhCN() {\n        return zhCN;\n      },\n      get enUS() {\n        return enUS;\n      },\n      get i18n() {\n        return i18n;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","watch","computed","AnimatedCharacters","zhCN","enUS","i18n","lang","dict","value","t","key","row","langLabel","toggleLocale","global","locale","emit","__emit","username","password","rememberMe","showPassword","focusedField","isLoginError","isTyping","loading","formBanner","errorTimer","characterConfig","scale","mouseSensitivityX","mouseSensitivityY","pupilFollowFactor","onUsernameFocus","onUsernameBlur","onPasswordFocus","onPasswordBlur","togglePassword","clearFormErrors","handleLogin","trim","triggerError","Promise","r","setTimeout","localStorage","setItem","window","clearTimeout"],"sources":["/home/xiao/ppyy/mian/smartcampus_v7/smartcampus/frontend/src/components/LoginView.vue"],"sourcesContent":["<script setup>\nimport { ref, watch, computed } from 'vue'\nimport AnimatedCharacters from './AnimatedCharacters.vue'\nimport zhCN from '../i18n/zh-CN'\nimport enUS from '../i18n/en-US'\nimport i18n from '../i18n'\n\nconst lang = ref('zh-CN')\nconst dict = computed(() => (lang.value === 'zh-CN' ? zhCN : enUS))\n\nfunction t(key) {\n  const row = dict.value\n  return row[key] ?? key\n}\n\nconst langLabel = computed(() => (lang.value === 'zh-CN' ? 'English' : '中文'))\n\nfunction toggleLocale() {\n  lang.value = lang.value === 'zh-CN' ? 'en-US' : 'zh-CN'\n  i18n.global.locale.value = lang.value\n}\n\nconst emit = defineEmits(['login-success'])\n\nconst username = ref('')\nconst password = ref('')\nconst rememberMe = ref(false)\nconst showPassword = ref(false)\nconst focusedField = ref('none')\nconst isLoginError = ref(false)\nconst isTyping = ref(false)\nconst loading = ref(false)\n\nconst formBanner = ref('')\nlet errorTimer = null\n\nconst characterConfig = {\n  scale: 0.88,\n  mouseSensitivityX: 20,\n  mouseSensitivityY: 30,\n  pupilFollowFactor: 0.35,\n}\n\nfunction onUsernameFocus() { focusedField.value = 'email'; isTyping.value = true }\nfunction onUsernameBlur() { focusedField.value = 'none'; isTyping.value = false }\nfunction onPasswordFocus() { focusedField.value = 'password'; isTyping.value = true }\nfunction onPasswordBlur() { focusedField.value = 'none'; isTyping.value = false }\n\nfunction togglePassword() { showPassword.value = !showPassword.value }\n\nfunction clearFormErrors() {\n  formBanner.value = ''\n}\n\nasync function handleLogin() {\n  clearFormErrors()\n\n  if (!username.value.trim() || !password.value) {\n    formBanner.value = t('loginFailEmpty')\n    triggerError()\n    return\n  }\n\n  loading.value = true\n\n  // Mock 本地静态验证（纯前端调试阶段，暂不调用后端接口）\n  await new Promise(r => setTimeout(r, 600)) // 模拟网络延迟，保留加载态体验\n  if (username.value === 'admin' && password.value === '123456') {\n    localStorage.setItem('token', 'mock-local-token-12345')\n    emit('login-success')\n  } else {\n    formBanner.value = t('loginFailCheck')\n    triggerError()\n  }\n\n  loading.value = false\n}\n\nfunction triggerError() {\n  isLoginError.value = true\n  if (errorTimer) window.clearTimeout(errorTimer)\n  errorTimer = window.setTimeout(() => { isLoginError.value = false }, 2200)\n}\n\nwatch([username, password], () => {\n  clearFormErrors()\n  if (isLoginError.value) {\n    isLoginError.value = false\n    if (errorTimer) { window.clearTimeout(errorTimer); errorTimer = null }\n  }\n})\n</script>\n\n<template>\n  <div class=\"login-page\">\n    <div class=\"login-shell\">\n      <section class=\"left-panel\">\n        <AnimatedCharacters\n          :config=\"characterConfig\"\n          :focused-field=\"focusedField\"\n          :is-password-visible=\"showPassword\"\n          :password-length=\"password.length\"\n          :is-login-error=\"isLoginError\"\n          :is-typing=\"isTyping\"\n        />\n      </section>\n\n      <section class=\"right-panel\">\n        <div class=\"form-card\">\n          <button class=\"lang-btn\" type=\"button\" @click.stop.prevent=\"toggleLocale\">\n            <svg width=\"14\" height=\"14\"
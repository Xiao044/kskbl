 \"dropdown-item\",\n      onClick: _cache[7] || (_cache[7] = _withModifiers($event => $data.showUserMenu = false, [\"stop\"]))\n    }, [...(_cache[23] || (_cache[23] = [_createElementVNode(\"svg\", {\n      width: \"14\",\n      height: \"14\",\n      viewBox: \"0 0 24 24\",\n      fill: \"none\",\n      stroke: \"currentColor\",\n      \"stroke-width\": \"2\",\n      \"stroke-linecap\": \"round\",\n      \"stroke-linejoin\": \"round\"\n    }, [_createElementVNode(\"rect\", {\n      x: \"3\",\n      y: \"11\",\n      width: \"18\",\n      height: \"11\",\n      rx: \"2\",\n      ry: \"2\"\n    }), _createElementVNode(\"path\", {\n      d: \"M7 11V7a5 5 0 0 1 10 0v4\"\n    })], -1 /* CACHED */), _createTextVNode(\" 修改密码 \", -1 /* CACHED */)]))]), _cache[25] || (_cache[25] = _createElementVNode(\"div\", {\n      class: \"dropdown-divider\"\n    }, null, -1 /* CACHED */)), _createElementVNode(\"a\", {\n      class: \"dropdown-item dropdown-item--danger\",\n      onClick: _cache[8] || (_cache[8] = _withModifiers((...args) => $options.handleLogout && $options.handleLogout(...args), [\"stop\"]))\n    }, [...(_cache[24] || (_cache[24] = [_createElementVNode(\"svg\", {\n      width: \"14\",\n      height: \"14\",\n      viewBox: \"0 0 24 24\",\n      fill: \"none\",\n      stroke: \"currentColor\",\n      \"stroke-width\": \"2\",\n      \"stroke-linecap\": \"round\",\n      \"stroke-linejoin\": \"round\"\n    }, [_createElementVNode(\"path\", {\n      d: \"M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4\"\n    }), _createElementVNode(\"polyline\", {\n      points: \"16 17 21 12 16 7\"\n    }), _createElementVNode(\"line\", {\n      x1: \"21\",\n      y1: \"12\",\n      x2: \"9\",\n      y2: \"12\"\n    })], -1 /* CACHED */), _createTextVNode(\" 退出登录 \", -1 /* CACHED */)]))])])) : _createCommentVNode(\"v-if\", true)]),\n    _: 1 /* STABLE */\n  })])), [[_directive_click_outside, () => $data.showUserMenu = false]])])]), _createElementVNode(\"div\", _hoisted_12, [_createElementVNode(
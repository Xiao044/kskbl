{"ast":null,"code":"import { createCommentVNode as _createCommentVNode, normalizeStyle as _normalizeStyle, openBlock as _openBlock, createElementBlock as _createElementBlock, normalizeClass as _normalizeClass, createElementVNode as _createElementVNode, Teleport as _Teleport, createBlock as _createBlock, Fragment as _Fragment } from \"vue\";\nconst _hoisted_1 = {\n  class: \"mascot-scale\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(_Fragment, null, [_createCommentVNode(\"\\n    Teleport to body: escapes sidebar's overflow:hidden AND the drawer backdrop blur.\\n    Visual position is still anchored to the sidebar via CSS.\\n  \"), (_openBlock(), _createBlock(_Teleport, {\n    to: \"body\"\n  }, [_createElementVNode(\"div\", {\n    class: _normalizeClass([\"mascot-fixed\", {\n      'is-hidden': $props.isCollapsed\n    }]),\n    ref: \"wrapRef\",\n    onMouseenter: _cache[0] || (_cache[0] = $event => $setup.isHovering = true),\n    onMouseleave: _cache[1] || (_cache[1] = $event => $setup.isHovering = false),\n    onClick: _cache[2] || (_cache[2] = $event => $setup.emit('open-chat'))\n  }, [_createCommentVNode(\" Scale wrapper: 240×204 at original size \"), _createElementVNode(\"div\", _hoisted_1, [_createElementVNode(\"div\", {\n    class: \"m-orange\",\n    style: _normalizeStyle($setup.orangeStyle)\n  }, [_createElementVNode(\"div\", {\n    class: \"m-eyes\",\n    style: _normalizeStyle($setup.orangeEyesStyle)\n  }, [_createElementVNode(\"span\", {\n    class: _normalizeClass([\"m-eye m-eye-dark\", {\n      blink: $setup.isBlinking\n    }])\n  }, [!$setup.isBlinking ? (_openBlock(), _createElementBlock(\"span\", {\n    key: 0,\n    class: \"m-pupil m-pupil-dark\",\n    style: _normalizeStyle($setup.pupilDarkStyle)\n  }, null, 4 /* STYLE */)) : _createCommentVNode(\"v-if\", true)], 2 /* CLASS */), _createElementVNode(\"span\", {\n    class: _normalizeClass([\"m-eye m-eye-dark\", {\n      blink: $setup.isBlinking\n    }])\n  }, [!$setup.isBlinking ? (_openBlock(), _createElementBlock(\"span\", {\n    key: 0,\n    class: \"m-pupil m-pupil-dark\",\n    style: _normalizeStyle($setup.pupilDarkStyle)\n  }, null, 4 /* STYLE */)) : _createCommentVNode(\"v-if\", true)], 2 /* CLASS */)], 4 /* STYLE */), _createElementVNode(\"span\", {\n    class: \"m-mouth\",\n    style: _normalizeStyle($setup.orangeMouthStyle)\n  }, null, 4 /* STYLE */), _cache[3] || (_cache[3] = _createElementVNode(\"div\", {\n    class: \"m-shine\"\n  }, null, -1 /* CACHED */))], 4 /* STYLE */)]), _createCommentVNode(\" Clay hard-edge shadow \"), _cache[4] || (_cache[4] = _createElementVNode(\"div\", {\n    class: \"m-clay-shadow\"\n  }, null, -1 /* CACHED */))], 34 /* CLASS, NEED_HYDRATION */)]))], 2112 /* STABLE_FRAGMENT, DEV_ROOT_FRAGMENT */);\n}","map":{"version":3,"names":["class","_createCommentVNode","_createBlock","_Teleport","to","_createElementVNode","_normalizeClass","$props","isCollapsed","ref","onMouseenter","_cache","$event","$setup","isHovering","onMouseleave","onClick","emit","_hoisted_1","style","_normalizeStyle","orangeStyle","orangeEyesStyle","blink","isBlinking","_createElementBlock","pupilDarkStyle","orangeMouthStyle"],"sources":["/home/xiao/ppyy/mian/smartcampus_v7/smartcampus/frontend/src/components/ChatMascotHandle.vue"],"sourcesContent":["<script setup>\nimport { computed, onBeforeUnmount, onMounted, ref, nextTick, watch } from 'vue'\n\nconst props = defineProps({\n  isCollapsed: { type: Boolean, default: false },\n  isChatFocused: { type: Boolean, default: false },\n  isInteractiveEnabled: { type: Boolean, default: true },\n})\nconst emit = defineEmits(['open-chat'])\n\n/* Scale: original orange character is 240×204\n   0.58 → visual ≈ 139×118 — bigger, more impactful */\nconst SCALE = 0.58\n\n/* ---- Refs ---- */\nconst wrapRef = ref(null)\nconst mouseX = ref(0)\nconst mouseY = ref(0)\nconst isHovering = ref(false)\nconst isBlinking = ref(false)\nlet rafId = null\nlet blinkTimer = null\n\nfunction clamp(v, min, max) {\n  return Math.max(min, Math.min(max, v))\n}\n\n/* ---- rAF-throttled mouse tracking ---- */\nlet pendingMX = 0\nlet pendingMY = 0\nlet dirty = false\n\nfunction onMouseMove(e) {\n  if (!props.isInteractiveEnabled) return\n  pendingMX = e.clientX\n  pendingMY = e.clientY\n  if (!dirty) {\n    dirty = true\n    rafId = requestAnimationFrame(flushMouse)\n  }\n}\nfunction flushMouse() {\n  dirty = false\n  mouseX.value = pendingMX\n  mouseY.value = pendingMY\n}\n\n/* ---- Blinking ---- */\nfunction scheduleBlink() {\n  const delay = 2500 + Math.random() * 3500\n  blinkTimer = window.setTimeout(() => {\n    isBlinking.value = true\n    window.setTimeout(() => {\n      isBlinking.value = false\n      scheduleBlink()\n    }, 140)\n  }, delay)\n}\n\n/* ---- Mouse offset — overrides to \"staring down\" when chat is focused ---- */\nconst mouseOffset = computed(() => {\n  if (props.isChatFocused) {\n    return { faceX: 0, faceY: 10 }\n  }\n  if (!wrapRef.value) return { faceX: 0, faceY: 0 }\n  const r = wrapRef.value.getBoundingClientRect()\n  const cx = r.left + r.width / 2\n  const cy = r.top + r.height * 0.4\n  const dx = mouseX.value - cx\n  const dy = mouseY.value - cy\n  return {\n    faceX: clamp(dx / 10, -15, 15),\n    faceY: clamp(dy / 14, -10, 10),\n  }\n})\n\n/* ---- Body style ---- */\nconst orangeStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  const squash = faceY * 0.011\n  const pull = Math.abs(faceX) * 0.004\n  const sx = 1 + squash + pull\n  const sy = 1 - squash - pull * 0.45\n  const skew = -faceX * 0.56\n  const lr = clamp(138 + faceX * 3.5 + faceY * 1.1, 100, 200)\n  const rr = clamp(138 - faceX * 3.5 + faceY * 1.1, 100, 200)\n  const hoverScale = isHovering.value ? 1.06 : 1\n  return {\n    transform: `scale(${hoverScale}) skewX(${skew.toFixed(2)}deg) scaleX(${sx.toFixed(3)}) scaleY(${sy.toFixed(3)})`,\n    transformOrigin: 'bottom center',\n    borderRadius: `${lr}px ${rr}px 0 0`,\n  }\n})\n\n/* ---- Eyes position ---- */\nconst orangeEyesStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  return {\n    left: `${85 + faceX * 2.4}px`,\n    top: `${90 + faceY * 1.45 - faceX * 0.24}px`,\n    transform: `rotate(${(faceX * 0.42).toFixed(2)}deg)`,\n  }\n})\n\n/* ---- Pupils ---- */\nconst pupilDarkStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  return {\n    transform: `translate3d(${faceX * 0.35}px, ${faceY * 0.35}px, 0)`,\n  }\n})\n\n/* ---- Mouth ---- */\nconst orangeMouthStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  if (isHovering.value) {\n    return {\n      width: '28px', height: '14px',\n      borderRadius: '0 0 28px 28px',\n      background: '#2D2D2D',\n      left: `${113 + faceX * 2.2}px`,\n      top: `${117 + faceY * 1.6 - faceX * 0.16}px`,\n      transform: 'translateX(-50%)',\n    }\n  }\n  if (props.isChatFocused) {\n    return {\n      width: '14px', height: '14px',\n      borderRadius: '50%',\n      background: '#2D2D2D',\n      left: `${113 + faceX * 2.2}px`,\n      top: `${118 + faceY * 1.6 - faceX * 0.16}px`,\n      transform: 'translateX(-50%)',\n    }\n  }\n  return {\n    width: '24px', height: '12px',\n    borderRadius: '0 0 24px 24px',\n    background: '#2D2D2D',\n    left: `${113 + faceX * 2.2}px`,\n    top: `${117 + faceY * 1.6 - faceX * 0.16}px`,\n    transform: `translateX(-50%) rotate(${(faceX * 0.34).toFixed(2)}deg)`,\n  }\n})\n\n/* ---- Lifecycle ---- */\nonMounted(() => {\n  if (props.isInteractiveEnabled) {\n    window.addEventListener('mousemove', onMouseMove, { passive: true })\n  }\n  scheduleBlink()\n  nextTick(() => {\n    if (wrapRef.value) {\n      const r = wrapRef.value.getBoundingClientRect()\n      mouseX.value = r.left + r.width / 2\n      mouseY.value = r.top + r.height * 0.4\n    }\n  })\n})\n\nwatch(() => props.isInteractiveEnabled, (enabled) => {\n  if (enabled) {\n    window.addEventListener('mousemove', onMouseMove, { passive: true })\n    nextTick(() => {\n      if (wrapRef.value) {\n        const r = wrapRef.value.getBoundingClientRect()\n        mouseX.value = r.left + r.width / 2\n        mouseY.value = r.top + r.height * 0.4\n      }\n    })\n    return\n  }\n\n  window.removeEventListener('mousemove', onMouseMove)\n  if (rafId) {\n    cancelAnimationFrame(rafId)\n    rafId = null\n  }\n  dirty = false\n})\n\nonBeforeUnmount(() => {\n  window.removeEventListener('mousemove', onMouseMove)\n  if (rafId) cancelAnimationFrame(rafId)\n  if (blinkTimer) clearTimeout(blinkTimer)\n})\n</script>\n\n<template>\n  <!--\n    Teleport to body: escapes sidebar's overflow:hidden AND the drawer backdrop blur.\n    Visual position is still anchored to the sidebar via CSS.\n  -->\n  <Teleport to=\"body\">\n    <div\n      class=\"mascot-fixed\"\n      :class=\"{ 'is-hidden': isCollapsed }\"\n      ref=\"wrapRef\"\n      @mouseenter=\"isHovering = true\"\n      @mouseleave=\"isHovering = false\"\n      @click=\"emit('open-chat')\"\n    >\n      <!-- Scale wrapper: 240×204 at original size -->\n      <div class=\"mascot-scale\">\n        <div class=\"m-orange\" :style=\"orangeStyle\">\n          <div class=\"m-eyes\" :style=\"orangeEyesStyle\">\n            <span class=\"m-eye m-eye-dark\" :class=\"{ blink: isBlinking }\">\n              <span v-if=\"!isBlinking\" class=\"m-pupil m-pupil-dark\" :style=\"pupilDarkStyle\" />\n            </span>\n            <span class=\"m-eye m-eye-dark\" :class=\"{ blink: isBlinking }\">\n              <span v-if=\"!isBlinking\" class=\"m-pupil m-pupil-dark\" :style=\"pupilDarkStyle\" />\n            </span>\n          </div>\n          <span class=\"m-mouth\" :style=\"orangeMouthStyle\" />\n          <div class=\"m-shine\"></div>\n        </div>\n      </div>\n      <!-- Clay hard-edge shadow -->\n      <div class=\"m-clay-shadow\"></div>\n    </div>\n  </Teleport>\n</template>\n\n<style scoped>\n/* ===== Fixed-position mascot on body (teleported out of sidebar) ===== */\n/* z-index: 95 — above backdrop (90), below drawer (100) */\n.mascot-fixed {\n  position: fixed;\n  left: 48px;\n  bottom: 44px;\n  width: 139px;\n  height: 118px;\n  cursor: pointer;\n  z-index: 95;\n  /* Smooth show/hide with sidebar collapse */\n  transition: opacity 0.35s ease, transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n.mascot-fixed.is-hidden {\n  opacity: 0;\n  transform: translateX(-20px);\n  pointer-events: none;\n}\n\n/* ===== Scale wrapper — original 240×204 ===== */\n.mascot-scale {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 240px;\n  height: 204px;\n  transform: scale(0.58);\n  transform-origin: 0 0;\n  pointer-events: none;\n}\n\n/* ===== Orange body — EXACT original 240×204 ===== */\n.m-orange {\n  position: absolute;\n  left: 0;\n  bottom: 0;\n  width: 240px;\n  height: 204px;\n  background: #FF8433;\n  border-radius: 120px 120px 0 0;\n  z-index: 1;\n  overflow: hidden;\n  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),\n              border-radius 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);\n  box-shadow:\n    inset 0 -6px 12px rgba(0, 0, 0, 0.1),\n    inset 0 4px 8px rgba(255, 255, 255, 0.3);\n}\n\n/* ===== Eyes ===== */\n.m-eyes {\n  position: absolute;\n  display: flex;\n  gap: 36px;\n  align-items: center;\n  transition: left 0.5s ease-in-out, top 0.5s ease-in-out;\n}\n.m-eye {\n  position: relative;\n  width: 18px;\n  height: 18px;\n  border-radius: 50%;\n  background: #fff;\n  overflow: hidden;\n  box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.12);\n  transition: all 0.2s ease;\n  flex: 0 0 auto;\n}\n.m-eye-dark {\n  background: #111 !important;\n  box-shadow: none !important;\n  width: 12px !important;\n  height: 12px !important;\n}\n.m-eye.blink {\n  height: 2px !important;\n  margin-top: 5px;\n}\n\n/* ===== Pupils ===== */\n.m-pupil {\n  position: absolute;\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: #111;\n  top: 5px;\n  left: 5px;\n  transition: transform 0.75s cubic-bezier(0.22, 0.61, 0.36, 1);\n}\n.m-pupil-dark {\n  top: 4px;\n  left: 4px;\n}\n\n/* ===== Mouth ===== */\n.m-mouth {\n  position: absolute;\n  width: 24px;\n  height: 12px;\n  border-radius: 0 0 24px 24px;\n  background: #2D2D2D;\n  left: 109px;\n  top: 121px;\n  transform: translateX(-50%);\n  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),\n    left 0.5s ease-in-out, top 0.5s ease-in-out,\n    border-radius 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),\n    width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),\n    height 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);\n}\n\n/* ===== Glass shine ===== */\n.m-shine {\n  position: absolute;\n  top: 22px;\n  left: 36px;\n  width: 56px;\n  height: 32px;\n  background: rgba(255, 255, 255, 0.22);\n  border-radius: 50%;\n  transform: rotate(-12deg);\n  pointer-events: none;\n  z-index: 2;\n}\n\n/* ===== Clay hard-edge shadow ===== */\n.m-clay-shadow {\n  position: absolute;\n  bottom: 0;\n  left: 18px;\n  width: 104px;\n  height: 10px;\n  background: rgba(0, 0, 0, 0.1);\n  border-radius: 50%;\n  transform: scaleY(0.5);\n  box-shadow: 3px 2px 0 rgba(0, 0, 0, 0.05);\n  z-index: 0;\n  pointer-events: none;\n}\n</style>\n"],"mappings":";;EA2MWA,KAAK,EAAC;AAAc;;6DAd7BC,mBAAA,8JAGG,G,cACHC,YAAA,CA2BWC,SAAA;IA3BDC,EAAE,EAAC;EAAM,IACjBC,mBAAA,CAyBM;IAxBJL,KAAK,EAAAM,eAAA,EAAC,cAAc;MAAA,aACGC,MAAA,CAAAC;IAAW;IAClCC,GAAG,EAAC,SAAS;IACZC,YAAU,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEC,MAAA,CAAAC,UAAU;IACtBC,YAAU,EAAAJ,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEC,MAAA,CAAAC,UAAU;IACtBE,OAAK,EAAAL,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEC,MAAA,CAAAI,IAAI;MAEZhB,mBAAA,6CAAgD,EAChDI,mBAAA,CAaM,OAbNa,UAaM,GAZJb,mBAAA,CAWM;IAXDL,KAAK,EAAC,UAAU;IAAEmB,KAAK,EAAAC,eAAA,CAAEP,MAAA,CAAAQ,WAAW;MACvChB,mBAAA,CAOM;IAPDL,KAAK,EAAC,QAAQ;IAAEmB,KAAK,EAAAC,eAAA,CAAEP,MAAA,CAAAS,eAAe;MACzCjB,mBAAA,CAEO;IAFDL,KAAK,EAAAM,eAAA,EAAC,kBAAkB;MAAAiB,KAAA,EAAkBV,MAAA,CAAAW;IAAU;OAC3CX,MAAA,CAAAW,UAAU,I,cAAvBC,mBAAA,CAAgF;;IAAvDzB,KAAK,EAAC,sBAAsB;IAAEmB,KAAK,EAAAC,eAAA,CAAEP,MAAA,CAAAa,cAAc;iFAE9ErB,mBAAA,CAEO;IAFDL,KAAK,EAAAM,eAAA,EAAC,kBAAkB;MAAAiB,KAAA,EAAkBV,MAAA,CAAAW;IAAU;OAC3CX,MAAA,CAAAW,UAAU,I,cAAvBC,mBAAA,CAAgF;;IAAvDzB,KAAK,EAAC,sBAAsB;IAAEmB,KAAK,EAAAC,eAAA,CAAEP,MAAA,CAAAa,cAAc;kGAGhFrB,mBAAA,CAAkD;IAA5CL,KAAK,EAAC,SAAS;IAAEmB,KAAK,EAAAC,eAAA,CAAEP,MAAA,CAAAc,gBAAgB;qDAC9CtB,mBAAA,CAA2B;IAAtBL,KAAK,EAAC;EAAS,2B,oBAGxBC,mBAAA,2BAA8B,E,0BAC9BI,mBAAA,CAAiC;IAA5BL,KAAK,EAAC;EAAe,2B","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
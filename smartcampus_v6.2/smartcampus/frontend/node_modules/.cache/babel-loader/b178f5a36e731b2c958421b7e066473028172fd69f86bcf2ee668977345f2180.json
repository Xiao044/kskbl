VNode(\"svg\", {\n    width: \"18\",\n    height: \"18\",\n    viewBox: \"0 0 24 24\",\n    fill: \"none\",\n    stroke: \"currentColor\",\n    \"stroke-width\": \"2\",\n    \"stroke-linecap\": \"round\",\n    \"stroke-linejoin\": \"round\"\n  }, [_createElementVNode(\"line\", {\n    x1: \"3\",\n    y1: \"12\",\n    x2: \"21\",\n    y2: \"12\"\n  }), _createElementVNode(\"line\", {\n    x1: \"3\",\n    y1: \"6\",\n    x2: \"21\",\n    y2: \"6\"\n  }), _createElementVNode(\"line\", {\n    x1: \"3\",\n    y1: \"18\",\n    x2: \"21\",\n    y2: \"18\"\n  })], -1 /* CACHED */)]))], 8 /* PROPS */, _hoisted_3), _cache[16] || (_cache[16] = _createElementVNode(\"div\", {\n    class: \"brand\"\n  }, [_createElementVNode(\"div\", {\n    class: \"logo-icon\"\n  }, \"🛡️\"), _createElementVNode(\"div\", {\n    class: \"brand-text\"\n  }, [_createElementVNode(\"h2\", null, \"流量监督\"), _createElementVNode(\"span\", null, \"智慧校园态势感知系统\")])], -1 /* CACHED */)), _createElementVNode(\"nav\", _hoisted_4, [_createElementVNode(\"a\", {\n    class: _normalizeClass({\n      'active': $data.currentView === 'Dashboard'\n    }),\n    onClick: _cache[1] || (_cache[1] = $event => $data.currentView = 'Dashboard')\n  }, [...(_cache[8] || (_cache[8] = [_createElementVNode(\"span\", {\n    class: \"menu-icon\"\n  }, \"📊\", -1 /* CACHED */), _createElementVNode(\"span\", {\n    class: \"menu-label\"\n  }, \"全局态势看板\", -1 /* CACHED */)]))], 2 /* CLASS */), _createElementVNode(\"a\", {\n    class: _normalizeClass({\n      'active': $data.currentView === 'Realtime'\n    }),\n    onClick: _cache[2] || (_cache[2] = $event => $data.currentView = 'Realtime')\n  }, [...(_cache[9] || (_cache[9] = [_createElementVNode(\"span\", {\n    class: \"menu-icon\"\n  }, \"⚡\", -1 /* CACHED */), _createElementVNode(\"span\", {\n    class: \"menu-label\"\n  }, \"瞬时活跃监控\", -1 /* CACHED */)]))], 2 /* CLASS */), _createElementVNode(\"a\", {\n    class: _normalizeClass({\n      'active': $data.currentView === 'Rank'\n    }),\n
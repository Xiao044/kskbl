{"ast":null,"code":"import { createCommentVNode as _createCommentVNode, createElementVNode as _createElementVNode, normalizeStyle as _normalizeStyle, openBlock as _openBlock, createElementBlock as _createElementBlock, normalizeClass as _normalizeClass } from \"vue\";\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(\"div\", {\n    class: _normalizeClass([\"mascot-handle\", {\n      'is-drawer-open': $props.isOpen,\n      'is-hovered': $setup.isHovering\n    }]),\n    onMouseenter: _cache[0] || (_cache[0] = $event => $setup.isHovering = true),\n    onMouseleave: _cache[1] || (_cache[1] = $event => $setup.isHovering = false),\n    onClick: _cache[2] || (_cache[2] = $event => $setup.emit('toggle'))\n  }, [_createCommentVNode(\" Clay hard-edge figurine shadow (Clay style: solid offset, minimal blur) \"), _cache[3] || (_cache[3] = _createElementVNode(\"div\", {\n    class: \"clay-hard-shadow\"\n  }, null, -1 /* CACHED */)), _createCommentVNode(\" Glass reflection arc on body \"), _cache[4] || (_cache[4] = _createElementVNode(\"div\", {\n    class: \"clay-shine\"\n  }, null, -1 /* CACHED */)), _createCommentVNode(\" Orange monster body \"), _createElementVNode(\"div\", {\n    ref: \"mascotRef\",\n    class: \"mh-body\",\n    style: _normalizeStyle($setup.bodyStyle)\n  }, [_createElementVNode(\"div\", {\n    class: \"mh-eyes\",\n    style: _normalizeStyle($setup.eyesStyle)\n  }, [_createElementVNode(\"span\", {\n    class: _normalizeClass([\"mh-eye\", {\n      blink: $setup.isBlinking\n    }])\n  }, [!$setup.isBlinking ? (_openBlock(), _createElementBlock(\"span\", {\n    key: 0,\n    class: \"mh-pupil\",\n    style: _normalizeStyle($setup.pupilStyle)\n  }, null, 4 /* STYLE */)) : _createCommentVNode(\"v-if\", true)], 2 /* CLASS */), _createElementVNode(\"span\", {\n    class: _normalizeClass([\"mh-eye\", {\n      blink: $setup.isBlinking\n    }])\n  }, [!$setup.isBlinking ? (_openBlock(), _createElementBlock(\"span\", {\n    key: 0,\n    class: \"mh-pupil\",\n    style: _normalizeStyle($setup.pupilStyle)\n  }, null, 4 /* STYLE */)) : _createCommentVNode(\"v-if\", true)], 2 /* CLASS */)], 4 /* STYLE */), _createElementVNode(\"span\", {\n    class: \"mh-mouth\",\n    style: _normalizeStyle($setup.mouthStyle)\n  }, null, 4 /* STYLE */)], 4 /* STYLE */)], 34 /* CLASS, NEED_HYDRATION */);\n}","map":{"version":3,"names":["_createElementBlock","class","_normalizeClass","$props","isOpen","$setup","isHovering","onMouseenter","_cache","$event","onMouseleave","onClick","emit","_createCommentVNode","_createElementVNode","ref","style","_normalizeStyle","bodyStyle","eyesStyle","blink","isBlinking","pupilStyle","mouthStyle"],"sources":["/home/xiao/ppyy/mian/smartcampus_v6.2/smartcampus/frontend/src/components/ChatMascotHandle.vue"],"sourcesContent":["<script setup>\nimport { computed, onBeforeUnmount, onMounted, ref, nextTick, watch } from 'vue'\n\nconst props = defineProps({\n  isOpen: { type: Boolean, default: false },\n})\nconst emit = defineEmits(['toggle'])\n\n/* ---- Refs ---- */\nconst mascotRef = ref(null)\nconst mouseX = ref(0)\nconst mouseY = ref(0)\nconst isHovering = ref(false)\nconst isBlinking = ref(false)\nconst isTransitioning = ref(false)\nlet rafId = null\nlet blinkTimer = null\n\n/* ---- Helpers ---- */\nfunction clamp(v, min, max) {\n  return Math.max(min, Math.min(max, v))\n}\n\n/* ---- rAF-throttled mouse tracking ---- */\nlet pendingMX = 0\nlet pendingMY = 0\nlet dirty = false\n\nfunction onMouseMove(e) {\n  pendingMX = e.clientX\n  pendingMY = e.clientY\n  if (!dirty) {\n    dirty = true\n    rafId = requestAnimationFrame(flushMouse)\n  }\n}\nfunction flushMouse() {\n  dirty = false\n  mouseX.value = pendingMX\n  mouseY.value = pendingMY\n}\n\n/* ---- Blinking ---- */\nfunction scheduleBlink() {\n  const delay = 2500 + Math.random() * 3500\n  blinkTimer = window.setTimeout(() => {\n    isBlinking.value = true\n    window.setTimeout(() => {\n      isBlinking.value = false\n      scheduleBlink()\n    }, 140)\n  }, delay)\n}\n\n/* ---- Track drawer open transition to suppress mouse jump ---- */\nwatch(() => props.isOpen, () => {\n  isTransitioning.value = true\n  setTimeout(() => { isTransitioning.value = false }, 550)\n})\n\n/* ---- Derived mouse offset relative to mascot center ---- */\nconst mouseOffset = computed(() => {\n  if (!mascotRef.value) return { faceX: 0, faceY: 0 }\n  const r = mascotRef.value.getBoundingClientRect()\n  const cx = r.left + r.width / 2\n  const cy = r.top + r.height * 0.4\n  const dx = mouseX.value - cx\n  const dy = mouseY.value - cy\n  return {\n    faceX: clamp(dx / 18, -12, 12),\n    faceY: clamp(dy / 25, -8, 8),\n  }\n})\n\n/* ---- Body style ---- */\nconst bodyStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  const squash = faceY * 0.011\n  const pull = Math.abs(faceX) * 0.004\n  const sx = 1 + squash + pull\n  const sy = 1 - squash - pull * 0.45\n  const skew = -faceX * 0.56\n  const lr = clamp(138 + faceX * 3.5 + faceY * 1.1, 100, 200)\n  const rr = clamp(138 - faceX * 3.5 + faceY * 1.1, 100, 200)\n  const hoverScale = isHovering.value ? 1.12 : 1\n  return {\n    transform: `scale(${hoverScale}) skewX(${skew.toFixed(2)}deg) scaleX(${sx.toFixed(3)}) scaleY(${sy.toFixed(3)})`,\n    transformOrigin: 'bottom center',\n    borderRadius: `${lr}px ${rr}px 0 0`,\n  }\n})\n\n/* ---- Eyes position ---- */\nconst eyesStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  return {\n    left: `${85 + faceX * 2.4}px`,\n    top: `${90 + faceY * 1.45 - faceX * 0.24}px`,\n    transform: `rotate(${(faceX * 0.42).toFixed(2)}deg)`,\n  }\n})\n\n/* ---- Pupils ---- */\nconst pupilStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  return {\n    transform: `translate3d(${faceX * 0.35}px, ${faceY * 0.35}px, 0)`,\n  }\n})\n\n/* ---- Mouth: changes based on hover + drawer state ---- */\nconst mouthStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  if (isHovering.value) {\n    // Excited open mouth when hoverable\n    return {\n      width: '28px', height: '16px',\n      borderRadius: '0 0 28px 28px',\n      background: '#2D2D2D',\n      left: `${113 + faceX * 2.2}px`,\n      top: `${115 + faceY * 1.6 - faceX * 0.16}px`,\n      transform: 'translateX(-50%)',\n    }\n  }\n  if (props.isOpen) {\n    // Smirk / happy when drawer is open\n    return {\n      width: '22px', height: '8px',\n      borderRadius: '0 0 22px 22px',\n      background: '#2D2D2D',\n      left: `${113 + faceX * 2.2}px`,\n      top: `${118 + faceY * 1.6 - faceX * 0.16}px`,\n      transform: `translateX(-50%)`,\n    }\n  }\n  // Default smile\n  return {\n    width: '24px', height: '12px',\n    borderRadius: '0 0 24px 24px',\n    background: '#2D2D2D',\n    left: `${113 + faceX * 2.2}px`,\n    top: `${117 + faceY * 1.6 - faceX * 0.16}px`,\n    transform: `translateX(-50%) rotate(${(faceX * 0.34).toFixed(2)}deg)`,\n  }\n})\n\n/* ---- Lifecycle ---- */\nonMounted(() => {\n  window.addEventListener('mousemove', onMouseMove, { passive: true })\n  scheduleBlink()\n  nextTick(() => {\n    if (mascotRef.value) {\n      const r = mascotRef.value.getBoundingClientRect()\n      mouseX.value = r.left + r.width / 2\n      mouseY.value = r.top + r.height * 0.4\n    }\n  })\n})\nonBeforeUnmount(() => {\n  window.removeEventListener('mousemove', onMouseMove)\n  if (rafId) cancelAnimationFrame(rafId)\n  if (blinkTimer) clearTimeout(blinkTimer)\n})\n</script>\n\n<template>\n  <div\n    class=\"mascot-handle\"\n    :class=\"{ 'is-drawer-open': isOpen, 'is-hovered': isHovering }\"\n    @mouseenter=\"isHovering = true\"\n    @mouseleave=\"isHovering = false\"\n    @click=\"emit('toggle')\"\n  >\n    <!-- Clay hard-edge figurine shadow (Clay style: solid offset, minimal blur) -->\n    <div class=\"clay-hard-shadow\"></div>\n    <!-- Glass reflection arc on body -->\n    <div class=\"clay-shine\"></div>\n\n    <!-- Orange monster body -->\n    <div ref=\"mascotRef\" class=\"mh-body\" :style=\"bodyStyle\">\n      <div class=\"mh-eyes\" :style=\"eyesStyle\">\n        <span class=\"mh-eye\" :class=\"{ blink: isBlinking }\">\n          <span v-if=\"!isBlinking\" class=\"mh-pupil\" :style=\"pupilStyle\" />\n        </span>\n        <span class=\"mh-eye\" :class=\"{ blink: isBlinking }\">\n          <span v-if=\"!isBlinking\" class=\"mh-pupil\" :style=\"pupilStyle\" />\n        </span>\n      </div>\n      <span class=\"mh-mouth\" :style=\"mouthStyle\" />\n    </div>\n  </div>\n</template>\n\n<style scoped>\n/* ===== Root Handle ===== */\n.mascot-handle {\n  position: absolute;\n  left: -76px;\n  top: 50%;\n  transform: translateY(-50%);\n  width: 120px;\n  height: 115px;\n  cursor: pointer;\n  z-index: 10;\n  transition: left 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);\n}\n/* When drawer is open, nudge mascot slightly toward the panel */\n.mascot-handle.is-drawer-open {\n  left: -72px;\n}\n\n/* ===== Clay Hard-Edge Shadow ===== */\n/* Mimics the Clay design's signature solid offset shadow (--clay-shadow-hover: rgb(0,0,0) -7px 7px)\n   Creates the illusion of a physical clay figurine sitting on a glass surface */\n.clay-hard-shadow {\n  position: absolute;\n  bottom: 2px;\n  left: 18px;\n  width: 84px;\n  height: 12px;\n  background: rgba(0, 0, 0, 0.13);\n  border-radius: 50%;\n  z-index: 0;\n  /* Hard edge = large spread, tiny blur */\n  box-shadow: 4px 3px 0 rgba(0, 0, 0, 0.06);\n  transform: scaleY(0.55);\n}\n\n/* ===== Clay Body Shine (glass reflection) ===== */\n.clay-shine {\n  position: absolute;\n  top: 14px;\n  left: 22px;\n  width: 32px;\n  height: 18px;\n  background: rgba(255, 255, 255, 0.35);\n  border-radius: 50%;\n  transform: rotate(-15deg);\n  z-index: 3;\n  pointer-events: none;\n  transition: opacity 0.3s;\n}\n.mascot-handle.is-hovered .clay-shine {\n  opacity: 0.55;\n}\n\n/* ===== Orange Monster Body ===== */\n.mh-body {\n  position: absolute;\n  bottom: 0;\n  left: 0;\n  width: 120px;\n  height: 102px;\n  background: #FF8433;\n  border-radius: 60px 60px 0 0;\n  z-index: 1;\n  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),\n              border-radius 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);\n  /* Clay inset edge: inner shadow for 3D depth */\n  box-shadow:\n    inset 0 -4px 8px rgba(0, 0, 0, 0.1),\n    inset 0 3px 6px rgba(255, 255, 255, 0.3);\n}\n/* Hover: slight lift + Clay-style hard drop shadow */\n.mascot-handle.is-hovered .mh-body {\n  box-shadow:\n    inset 0 -4px 8px rgba(0, 0, 0, 0.1),\n    inset 0 3px 6px rgba(255, 255, 255, 0.3),\n    -4px 6px 0 rgba(0, 0, 0, 0.08);\n}\n\n/* ===== Eyes ===== */\n.mh-eyes {\n  position: absolute;\n  display: flex;\n  gap: 18px;\n  align-items: center;\n  transition: left 0.5s ease-in-out, top 0.5s ease-in-out;\n}\n.mh-eye {\n  position: relative;\n  width: 12px;\n  height: 12px;\n  border-radius: 50%;\n  background: #111;\n  overflow: hidden;\n  transition: all 0.15s ease;\n  flex: 0 0 auto;\n}\n.mh-eye.blink {\n  height: 2px !important;\n  margin-top: 5px;\n}\n\n/* ===== Pupils ===== */\n.mh-pupil {\n  position: absolute;\n  width: 6px;\n  height: 6px;\n  border-radius: 50%;\n  background: #FF8433;\n  top: 3px;\n  left: 3px;\n  transition: transform 0.65s cubic-bezier(0.22, 0.61, 0.36, 1);\n}\n\n/* ===== Mouth ===== */\n.mh-mouth {\n  position: absolute;\n  background: #2D2D2D;\n  transform: translateX(-50%);\n  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),\n    left 0.35s ease-in-out, top 0.35s ease-in-out,\n    border-radius 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),\n    width 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),\n    height 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\n}\n</style>\n"],"mappings":";;uBAsKEA,mBAAA,CAwBM;IAvBJC,KAAK,EAAAC,eAAA,EAAC,eAAe;MAAA,kBACOC,MAAA,CAAAC,MAAM;MAAA,cAAgBC,MAAA,CAAAC;IAAU;IAC3DC,YAAU,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEJ,MAAA,CAAAC,UAAU;IACtBI,YAAU,EAAAF,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEJ,MAAA,CAAAC,UAAU;IACtBK,OAAK,EAAAH,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEJ,MAAA,CAAAO,IAAI;MAEZC,mBAAA,6EAAgF,E,0BAChFC,mBAAA,CAAoC;IAA/Bb,KAAK,EAAC;EAAkB,4BAC7BY,mBAAA,kCAAqC,E,0BACrCC,mBAAA,CAA8B;IAAzBb,KAAK,EAAC;EAAY,4BAEvBY,mBAAA,yBAA4B,EAC5BC,mBAAA,CAUM;IAVDC,GAAG,EAAC,WAAW;IAACd,KAAK,EAAC,SAAS;IAAEe,KAAK,EAAAC,eAAA,CAAEZ,MAAA,CAAAa,SAAS;MACpDJ,mBAAA,CAOM;IAPDb,KAAK,EAAC,SAAS;IAAEe,KAAK,EAAAC,eAAA,CAAEZ,MAAA,CAAAc,SAAS;MACpCL,mBAAA,CAEO;IAFDb,KAAK,EAAAC,eAAA,EAAC,QAAQ;MAAAkB,KAAA,EAAkBf,MAAA,CAAAgB;IAAU;OACjChB,MAAA,CAAAgB,UAAU,I,cAAvBrB,mBAAA,CAAgE;;IAAvCC,KAAK,EAAC,UAAU;IAAEe,KAAK,EAAAC,eAAA,CAAEZ,MAAA,CAAAiB,UAAU;iFAE9DR,mBAAA,CAEO;IAFDb,KAAK,EAAAC,eAAA,EAAC,QAAQ;MAAAkB,KAAA,EAAkBf,MAAA,CAAAgB;IAAU;OACjChB,MAAA,CAAAgB,UAAU,I,cAAvBrB,mBAAA,CAAgE;;IAAvCC,KAAK,EAAC,UAAU;IAAEe,KAAK,EAAAC,eAAA,CAAEZ,MAAA,CAAAiB,UAAU;kGAGhER,mBAAA,CAA6C;IAAvCb,KAAK,EAAC,UAAU;IAAEe,KAAK,EAAAC,eAAA,CAAEZ,MAAA,CAAAkB,UAAU","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
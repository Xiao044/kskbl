{"ast":null,"code":"import { createCommentVNode as _createCommentVNode, normalizeStyle as _normalizeStyle, openBlock as _openBlock, createElementBlock as _createElementBlock, normalizeClass as _normalizeClass, createElementVNode as _createElementVNode, Fragment as _Fragment } from \"vue\";\nconst _hoisted_1 = {\n  class: \"mascot-scale\"\n};\nexport function render(_ctx, _cache, $props, $setup, $data, $options) {\n  return _openBlock(), _createElementBlock(_Fragment, null, [_createCommentVNode(\" Sidebar slot: hides when sidebar is collapsed \"), _createElementVNode(\"div\", {\n    class: _normalizeClass([\"mascot-slot\", {\n      'is-hidden': $props.isCollapsed\n    }])\n  }, [_createCommentVNode(\" Visual container = scaled size (120×102) \"), _createElementVNode(\"div\", {\n    class: \"mascot-visual\",\n    ref: \"wrapRef\",\n    onMouseenter: _cache[0] || (_cache[0] = $event => $setup.isHovering = true),\n    onMouseleave: _cache[1] || (_cache[1] = $event => $setup.isHovering = false),\n    onClick: _cache[2] || (_cache[2] = $event => $setup.emit('open-chat'))\n  }, [_createCommentVNode(\" Scale wrapper: 240×204 at original size, visually 120×102 via CSS \"), _createElementVNode(\"div\", _hoisted_1, [_createCommentVNode(\" Orange body — exact original dimensions & CSS \"), _createElementVNode(\"div\", {\n    class: \"m-orange\",\n    style: _normalizeStyle($setup.orangeStyle)\n  }, [_createElementVNode(\"div\", {\n    class: \"m-eyes\",\n    style: _normalizeStyle($setup.orangeEyesStyle)\n  }, [_createElementVNode(\"span\", {\n    class: _normalizeClass([\"m-eye m-eye-dark\", {\n      blink: $setup.isBlinking\n    }])\n  }, [!$setup.isBlinking ? (_openBlock(), _createElementBlock(\"span\", {\n    key: 0,\n    class: \"m-pupil m-pupil-dark\",\n    style: _normalizeStyle($setup.pupilDarkStyle)\n  }, null, 4 /* STYLE */)) : _createCommentVNode(\"v-if\", true)], 2 /* CLASS */), _createElementVNode(\"span\", {\n    class: _normalizeClass([\"m-eye m-eye-dark\", {\n      blink: $setup.isBlinking\n    }])\n  }, [!$setup.isBlinking ? (_openBlock(), _createElementBlock(\"span\", {\n    key: 0,\n    class: \"m-pupil m-pupil-dark\",\n    style: _normalizeStyle($setup.pupilDarkStyle)\n  }, null, 4 /* STYLE */)) : _createCommentVNode(\"v-if\", true)], 2 /* CLASS */)], 4 /* STYLE */), _createElementVNode(\"span\", {\n    class: \"m-mouth\",\n    style: _normalizeStyle($setup.orangeMouthStyle)\n  }, null, 4 /* STYLE */), _createCommentVNode(\" Glass shine highlight \"), _cache[3] || (_cache[3] = _createElementVNode(\"div\", {\n    class: \"m-shine\"\n  }, null, -1 /* CACHED */))], 4 /* STYLE */)]), _createCommentVNode(\" Clay hard-edge shadow (sits below the body, in visual space) \"), _cache[4] || (_cache[4] = _createElementVNode(\"div\", {\n    class: \"m-clay-shadow\"\n  }, null, -1 /* CACHED */))], 544 /* NEED_HYDRATION, NEED_PATCH */)], 2 /* CLASS */)], 2112 /* STABLE_FRAGMENT, DEV_ROOT_FRAGMENT */);\n}","map":{"version":3,"names":["class","_createCommentVNode","_createElementVNode","_normalizeClass","$props","isCollapsed","ref","onMouseenter","_cache","$event","$setup","isHovering","onMouseleave","onClick","emit","_hoisted_1","style","_normalizeStyle","orangeStyle","orangeEyesStyle","blink","isBlinking","_createElementBlock","pupilDarkStyle","orangeMouthStyle"],"sources":["/home/xiao/ppyy/mian/smartcampus_v6.2/smartcampus/frontend/src/components/ChatMascotHandle.vue"],"sourcesContent":["<script setup>\nimport { computed, onBeforeUnmount, onMounted, ref, nextTick } from 'vue'\n\nconst props = defineProps({\n  isCollapsed: { type: Boolean, default: false },\n})\nconst emit = defineEmits(['open-chat'])\n\n/* Scale: original orange character is 240×204, visual target ≈ 120×102 */\nconst SCALE = 0.5\n\n/* ---- Refs ---- */\nconst wrapRef = ref(null)\nconst mouseX = ref(0)\nconst mouseY = ref(0)\nconst isHovering = ref(false)\nconst isBlinking = ref(false)\nlet rafId = null\nlet blinkTimer = null\n\nfunction clamp(v, min, max) {\n  return Math.max(min, Math.min(max, v))\n}\n\n/* ---- rAF-throttled mouse tracking ---- */\nlet pendingMX = 0\nlet pendingMY = 0\nlet dirty = false\n\nfunction onMouseMove(e) {\n  pendingMX = e.clientX\n  pendingMY = e.clientY\n  if (!dirty) {\n    dirty = true\n    rafId = requestAnimationFrame(flushMouse)\n  }\n}\nfunction flushMouse() {\n  dirty = false\n  mouseX.value = pendingMX\n  mouseY.value = pendingMY\n}\n\n/* ---- Blinking ---- */\nfunction scheduleBlink() {\n  const delay = 2500 + Math.random() * 3500\n  blinkTimer = window.setTimeout(() => {\n    isBlinking.value = true\n    window.setTimeout(() => {\n      isBlinking.value = false\n      scheduleBlink()\n    }, 140)\n  }, delay)\n}\n\n/* ---- Mouse offset (wider range compensates for 0.5× visual scale) ---- */\nconst mouseOffset = computed(() => {\n  if (!wrapRef.value) return { faceX: 0, faceY: 0 }\n  const r = wrapRef.value.getBoundingClientRect()\n  const cx = r.left + r.width / 2\n  const cy = r.top + r.height * 0.4\n  const dx = mouseX.value - cx\n  const dy = mouseY.value - cy\n  return {\n    faceX: clamp(dx / 10, -15, 15),\n    faceY: clamp(dy / 14, -10, 10),\n  }\n})\n\n/* ====================================================\n   Computed styles — EXACT copies from AnimatedCharacters.vue\n   operating in the original 240×204 coordinate space.\n   CSS scale(0.5) handles visual sizing automatically.\n   ==================================================== */\n\n/* ---- Body style (orangeStyle default branch) ---- */\nconst orangeStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  const squash = faceY * 0.011\n  const pull = Math.abs(faceX) * 0.004\n  const sx = 1 + squash + pull\n  const sy = 1 - squash - pull * 0.45\n  const skew = -faceX * 0.56\n  const lr = clamp(138 + faceX * 3.5 + faceY * 1.1, 100, 200)\n  const rr = clamp(138 - faceX * 3.5 + faceY * 1.1, 100, 200)\n  const hoverScale = isHovering.value ? 1.06 : 1\n  return {\n    transform: `scale(${hoverScale}) skewX(${skew.toFixed(2)}deg) scaleX(${sx.toFixed(3)}) scaleY(${sy.toFixed(3)})`,\n    transformOrigin: 'bottom center',\n    borderRadius: `${lr}px ${rr}px 0 0`,\n  }\n})\n\n/* ---- Eyes position (orangeEyesStyle default branch) ---- */\nconst orangeEyesStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  return {\n    left: `${85 + faceX * 2.4}px`,\n    top: `${90 + faceY * 1.45 - faceX * 0.24}px`,\n    transform: `rotate(${(faceX * 0.42).toFixed(2)}deg)`,\n  }\n})\n\n/* ---- Pupils (pupilDarkStyle default branch) ---- */\nconst pupilDarkStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  return {\n    transform: `translate3d(${faceX * 0.35}px, ${faceY * 0.35}px, 0)`,\n  }\n})\n\n/* ---- Mouth (orangeMouthStyle default + hover branch) ---- */\nconst orangeMouthStyle = computed(() => {\n  const { faceX, faceY } = mouseOffset.value\n  if (isHovering.value) {\n    return {\n      width: '28px', height: '14px',\n      borderRadius: '0 0 28px 28px',\n      background: '#2D2D2D',\n      left: `${113 + faceX * 2.2}px`,\n      top: `${117 + faceY * 1.6 - faceX * 0.16}px`,\n      transform: 'translateX(-50%)',\n    }\n  }\n  return {\n    width: '24px', height: '12px',\n    borderRadius: '0 0 24px 24px',\n    background: '#2D2D2D',\n    left: `${113 + faceX * 2.2}px`,\n    top: `${117 + faceY * 1.6 - faceX * 0.16}px`,\n    transform: `translateX(-50%) rotate(${(faceX * 0.34).toFixed(2)}deg)`,\n  }\n})\n\n/* ---- Lifecycle ---- */\nonMounted(() => {\n  window.addEventListener('mousemove', onMouseMove, { passive: true })\n  scheduleBlink()\n  nextTick(() => {\n    if (wrapRef.value) {\n      const r = wrapRef.value.getBoundingClientRect()\n      mouseX.value = r.left + r.width / 2\n      mouseY.value = r.top + r.height * 0.4\n    }\n  })\n})\nonBeforeUnmount(() => {\n  window.removeEventListener('mousemove', onMouseMove)\n  if (rafId) cancelAnimationFrame(rafId)\n  if (blinkTimer) clearTimeout(blinkTimer)\n})\n</script>\n\n<template>\n  <!-- Sidebar slot: hides when sidebar is collapsed -->\n  <div class=\"mascot-slot\" :class=\"{ 'is-hidden': isCollapsed }\">\n    <!-- Visual container = scaled size (120×102) -->\n    <div\n      class=\"mascot-visual\"\n      ref=\"wrapRef\"\n      @mouseenter=\"isHovering = true\"\n      @mouseleave=\"isHovering = false\"\n      @click=\"emit('open-chat')\"\n    >\n      <!-- Scale wrapper: 240×204 at original size, visually 120×102 via CSS -->\n      <div class=\"mascot-scale\">\n        <!-- Orange body — exact original dimensions & CSS -->\n        <div class=\"m-orange\" :style=\"orangeStyle\">\n          <div class=\"m-eyes\" :style=\"orangeEyesStyle\">\n            <span class=\"m-eye m-eye-dark\" :class=\"{ blink: isBlinking }\">\n              <span v-if=\"!isBlinking\" class=\"m-pupil m-pupil-dark\" :style=\"pupilDarkStyle\" />\n            </span>\n            <span class=\"m-eye m-eye-dark\" :class=\"{ blink: isBlinking }\">\n              <span v-if=\"!isBlinking\" class=\"m-pupil m-pupil-dark\" :style=\"pupilDarkStyle\" />\n            </span>\n          </div>\n          <span class=\"m-mouth\" :style=\"orangeMouthStyle\" />\n          <!-- Glass shine highlight -->\n          <div class=\"m-shine\"></div>\n        </div>\n      </div>\n      <!-- Clay hard-edge shadow (sits below the body, in visual space) -->\n      <div class=\"m-clay-shadow\"></div>\n    </div>\n  </div>\n</template>\n\n<style scoped>\n/* ===== Sidebar slot — show/hide with collapse ===== */\n.mascot-slot {\n  padding: 4px 12px 20px;\n  display: flex;\n  justify-content: center;\n  transition: opacity 0.35s ease, max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1),\n              padding 0.35s ease;\n  max-height: 130px;\n  overflow: hidden;\n}\n.mascot-slot.is-hidden {\n  opacity: 0;\n  max-height: 0;\n  padding-top: 0;\n  padding-bottom: 0;\n  pointer-events: none;\n}\n\n/* ===== Visual container — the scaled size ===== */\n.mascot-visual {\n  width: 120px;\n  height: 102px;\n  position: relative;\n  cursor: pointer;\n}\n\n/* ===== Scale wrapper — original 240×204 shrunk to visual 120×102 ===== */\n.mascot-scale {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 240px;\n  height: 204px;\n  transform: scale(0.5);\n  transform-origin: 0 0;\n  pointer-events: none;\n}\n\n/* ===== Orange body — EXACT match with AnimatedCharacters.vue .ac-orange ===== */\n.m-orange {\n  position: absolute;\n  left: 0;\n  bottom: 0;\n  width: 240px;\n  height: 204px;\n  background: #FF8433;\n  border-radius: 120px 120px 0 0;\n  z-index: 1;\n  overflow: hidden;\n  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),\n              border-radius 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);\n  /* Clay inset edges for 3D depth */\n  box-shadow:\n    inset 0 -6px 12px rgba(0, 0, 0, 0.1),\n    inset 0 4px 8px rgba(255, 255, 255, 0.3);\n}\n\n/* ===== Eyes — EXACT match with AnimatedCharacters.vue ===== */\n.m-eyes {\n  position: absolute;\n  display: flex;\n  gap: 36px;\n  align-items: center;\n  transition: left 0.5s ease-in-out, top 0.5s ease-in-out;\n}\n.m-eye {\n  position: relative;\n  width: 18px;\n  height: 18px;\n  border-radius: 50%;\n  background: #fff;\n  overflow: hidden;\n  box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.12);\n  transition: all 0.2s ease;\n  flex: 0 0 auto;\n}\n.m-eye-dark {\n  background: #111 !important;\n  box-shadow: none !important;\n  width: 12px !important;\n  height: 12px !important;\n}\n.m-eye.blink {\n  height: 2px !important;\n  margin-top: 5px;\n}\n\n/* ===== Pupils — EXACT match with AnimatedCharacters.vue ===== */\n.m-pupil {\n  position: absolute;\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: #111;\n  top: 5px;\n  left: 5px;\n  transition: transform 0.75s cubic-bezier(0.22, 0.61, 0.36, 1);\n}\n.m-pupil-dark {\n  top: 4px;\n  left: 4px;\n}\n\n/* ===== Mouth — EXACT match with AnimatedCharacters.vue .ac-orange .ac-mouth ===== */\n.m-mouth {\n  position: absolute;\n  width: 24px;\n  height: 12px;\n  border-radius: 0 0 24px 24px;\n  background: #2D2D2D;\n  left: 109px;\n  top: 121px;\n  transform: translateX(-50%);\n  transition: transform 0.5s ease-in-out, left 0.5s ease-in-out, top 0.5s ease-in-out,\n    border-radius 0.4s ease, width 0.4s ease, height 0.4s ease, opacity 0.3s ease, background 0.3s ease;\n}\n\n/* ===== Glass shine on body ===== */\n.m-shine {\n  position: absolute;\n  top: 22px;\n  left: 36px;\n  width: 56px;\n  height: 32px;\n  background: rgba(255, 255, 255, 0.22);\n  border-radius: 50%;\n  transform: rotate(-12deg);\n  pointer-events: none;\n  z-index: 2;\n}\n\n/* ===== Clay hard-edge shadow (in visual/scaled space) ===== */\n.m-clay-shadow {\n  position: absolute;\n  bottom: -2px;\n  left: 16px;\n  width: 88px;\n  height: 8px;\n  background: rgba(0, 0, 0, 0.1);\n  border-radius: 50%;\n  transform: scaleY(0.5);\n  /* Clay signature: solid offset shadow, near-zero blur */\n  box-shadow: 3px 2px 0 rgba(0, 0, 0, 0.05);\n  z-index: 0;\n  pointer-events: none;\n}\n</style>\n"],"mappings":";;EAqKWA,KAAK,EAAC;AAAc;;6DAX7BC,mBAAA,mDAAsD,EACtDC,mBAAA,CA6BM;IA7BDF,KAAK,EAAAG,eAAA,EAAC,aAAa;MAAA,aAAwBC,MAAA,CAAAC;IAAW;MACzDJ,mBAAA,8CAAiD,EACjDC,mBAAA,CA0BM;IAzBJF,KAAK,EAAC,eAAe;IACrBM,GAAG,EAAC,SAAS;IACZC,YAAU,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEC,MAAA,CAAAC,UAAU;IACtBC,YAAU,EAAAJ,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEC,MAAA,CAAAC,UAAU;IACtBE,OAAK,EAAAL,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEC,MAAA,CAAAI,IAAI;MAEZb,mBAAA,uEAA0E,EAC1EC,mBAAA,CAeM,OAfNa,UAeM,GAdJd,mBAAA,mDAAsD,EACtDC,mBAAA,CAYM;IAZDF,KAAK,EAAC,UAAU;IAAEgB,KAAK,EAAAC,eAAA,CAAEP,MAAA,CAAAQ,WAAW;MACvChB,mBAAA,CAOM;IAPDF,KAAK,EAAC,QAAQ;IAAEgB,KAAK,EAAAC,eAAA,CAAEP,MAAA,CAAAS,eAAe;MACzCjB,mBAAA,CAEO;IAFDF,KAAK,EAAAG,eAAA,EAAC,kBAAkB;MAAAiB,KAAA,EAAkBV,MAAA,CAAAW;IAAU;OAC3CX,MAAA,CAAAW,UAAU,I,cAAvBC,mBAAA,CAAgF;;IAAvDtB,KAAK,EAAC,sBAAsB;IAAEgB,KAAK,EAAAC,eAAA,CAAEP,MAAA,CAAAa,cAAc;iFAE9ErB,mBAAA,CAEO;IAFDF,KAAK,EAAAG,eAAA,EAAC,kBAAkB;MAAAiB,KAAA,EAAkBV,MAAA,CAAAW;IAAU;OAC3CX,MAAA,CAAAW,UAAU,I,cAAvBC,mBAAA,CAAgF;;IAAvDtB,KAAK,EAAC,sBAAsB;IAAEgB,KAAK,EAAAC,eAAA,CAAEP,MAAA,CAAAa,cAAc;kGAGhFrB,mBAAA,CAAkD;IAA5CF,KAAK,EAAC,SAAS;IAAEgB,KAAK,EAAAC,eAAA,CAAEP,MAAA,CAAAc,gBAAgB;2BAC9CvB,mBAAA,2BAA8B,E,0BAC9BC,mBAAA,CAA2B;IAAtBF,KAAK,EAAC;EAAS,2B,oBAGxBC,mBAAA,kEAAqE,E,0BACrEC,mBAAA,CAAiC;IAA5BF,KAAK,EAAC;EAAe,2B","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
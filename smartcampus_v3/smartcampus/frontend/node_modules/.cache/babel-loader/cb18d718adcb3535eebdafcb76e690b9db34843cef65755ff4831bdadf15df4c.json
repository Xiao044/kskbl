\n            <td class=\"threat-col\">{{ item.type }}</td>\n            <td class=\"ip-col\">{{ item.src_ip }} <span class=\"geo\">({{ item.geo_loc }})</span></td>\n            <td>{{ item.target }}</td>\n            <td>\n              <span :class=\"['risk-badge', item.level]\">{{ item.level === 'high' ? '高危' : '中危' }}</span>\n            </td>\n            <td class=\"status-col\">已拦截/记录</td>\n          </tr>\n          <tr v-if=\"alerts.length === 0\">\n            <td colspan=\"6\" class=\"empty-text\">当前网络环境安全，未检测到异常攻击行为</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts';\n\nexport default {\n  name: 'Alert',\n  props: {\n    // 监听实时流量，用于触发告警\n    flow: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      alerts: [],\n      radarInstance: null,\n      threatStats: {\n        'DDoS攻击': 0,\n        '端口扫描': 0,\n        '蠕虫病毒': 0,\n        '异常高频访问': 0,\n        '钓鱼/恶意伪造': 0\n      }\n    }\n  },\n  computed: {\n    reversedAlerts() {\n      return [...this.alerts].reverse();\n    },\n    highRiskCount() {\n      return this.alerts.filter(a => a.level === 'high').length;\n    }\n  },\n  watch: {\n    flow: {\n      handler(newData) {\n        this.detectThreats(newData);\n      },\n      deep: true\n    }\n  },\n  mounted() {\n    this.radarInstance = echarts.init(this.$refs.radarChart);\n    this.updateRadarChart();\n    window.addEventListener('resize', this.resizeChart);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.resizeChart);\n    if (this.radarInstance) this.radarInstance.dispose();\n  },\n  methods: {\n    // 基于前端的简易入侵检测系统 (IDS) 模拟\n    detectThreats(data) {\n      const now = new Date().toLocaleTimeString();\n      let hasNewThreat = false;\n\n      data.forEach(item => {\n        // 规则1：如果单IP在一秒内发包数过高，判定为 DDoS 或 洪泛攻击\n        if (item.packets > 500) {\n          this.alerts.push({\n            time: now, type: '疑似 DDoS 攻击 (洪泛)', src_ip: item.src_ip, \n            geo_loc: item.geo_loc, target: '多协议/全量', level: 'high'\n          });\n          this.threatStats['DDoS攻击']++;\n          hasNewThreat = true;\n        }\n        // 规则2：如果单IP同时使用多个协议且流量异常，疑似端口扫描\n        else if (item.protocols.length >= 3 && item.packets > 100) {\n          this.alerts.push({\n            time: now, type: '暴力端口扫描', src_ip: item.src_ip, \n            geo_loc: item.geo_loc, target: item.protocols.join(','), level: 'medium'\n          });\n          this.threatStats['端口扫描']++;\n          hasNewThreat = true;\n        }\n      });\n\n      // 保持日志最多保留 50 条\n      if (this.alerts.length > 50) this.alerts = this.alerts.slice(-50);\n      \n      if (hasNewThreat) this.updateRadarChart();\n    },\n    updateRadarChart() {\n      const option = {\n        title: { text: '攻击类型雷达分布图', textStyle: { color: '#e2e8f0', fontSize: 16 } },\n        tooltip: {},\n        radar: {\n          indicator: [\n            { name: 'DDoS攻击', max: Math.max(10, this.threatStats['DDoS攻击'] * 2) },\n            { name: '端口扫描', max: Math.max(10, this.threatStats['端口扫描'] * 2) },\n            { name: '蠕虫病毒', max: 10 },\n            { name: '异常高频访问', max: 10 },\n            { name: '钓鱼/伪造', max: 10 }\n          ],\n          splitArea: { areaStyle: { color: ['rgba(239, 68, 68, 0.1)', 'rgba(239, 68, 68, 0.05)', 'rgba(30, 41, 59, 0.5)'] } },\n          axisName: { color: '#94a3b8' }\n        },\n        series: [{\n          name: '威胁统计',\n          type: 'radar',\n          data: [{\n            value: [this.threatStats['DDoS攻击'], this.threatStats['端口扫描'], this.threatStats['蠕虫病毒'], this.threatStats['异常高频访问'], this.threatStats['钓鱼/恶意伪造']],\n            name: '威胁次数'\n          }],\n          itemStyle: { color: '#f87171' },\n          areaStyle: { color: 'rgba(248, 113, 113, 0.4)' }\n        }]\n      };\n      this.radarInstance.setOption(option);\n    },\n    resizeChart() {\n      if (this.radarInstance) this.radarInstance.resize();\n    }\n  }\n}\n</script>\n\n<style scoped>\n.alert-container { display: flex; flex-direction: column; gap: 20px; height: 100%; }\n.charts-row { display: flex; height: 280px; gap: 20px; }\n.chart-box { flex: 1.5; background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }\n.alert-summary { flex: 1; background: #1e293b; border-radius: 12px; padding: 25px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); display: flex; flex-direction: column; }\n.alert-summary h3 { margin-top: 0; color: #e2e8f0; border-bottom: 1px solid #334155; padding-bottom: 10px; }\n\n.engine-status { color: #a3e635; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: bold; }\n.status-indicator { width: 12px; height: 12px; border-radius: 50%; background: #a3e635; box-shadow: 0 0 8px #a3e635; }\n.scanning { animation: pulse 1.5s infinite; }\n@keyframes pulse { 0% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.2); } 100% { opacity: 1; transform: scale(1); } }\n\n.alert-stats { display: flex; gap: 20px; }\n.stat-item { background: #0f172a; padding: 15px; border-radius: 8px; flex: 1; text-align: center; border: 1px solid #334155; }\n.stat-item span { display: block; color: #94a3b8; font-size: 14px; }\n.stat-item .num { font-size: 28px; font-weight: bold; color: #38bdf8; margin-top: 5px; }\n.stat-item.danger { border-color: #7f1d1d; background: #450a0a; }\n.stat-item.danger .num { color: #f87171; }\n\n.table-box { flex: 1; background: #1e293b; border-radius: 12px; padding: 20px; overflow-y: auto; }\n.table-box h3 { margin-top: 0; margin-bottom: 15px; color: #f87171; }\ntable { width: 100%; border-collapse: collapse; }\nth, td { padding: 12px; text-align: left; border-bottom: 1px solid #334155; font-size: 14px; }\nth { color: #94a3b8; font-weight: 500; position: sticky; top: 0; background: #1e293b; }\n.time-col { color: #cbd5e1; }\n.threat-col { color: #f87171; font-weight: bold; }\n.ip-col { color: #e2e8f0; font-family: monospace; }\n.geo { color: #64748b; font-size: 12px; font-family: sans-serif; }\n.risk-badge { padding: 3px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; }\n.risk-badge.high { background: #7f1d1d; color: #fca5a5; }\n.risk-badge.medium { background: #78350f; color: #fcd34d; }\n.status-col { color: #22c55e; }\n.empty-text { text-align: center; color: #64748b; padding: 30px !important; }\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAiB;;EACrBA,KAAK,EAAC;AAAY;;EAChBA,KAAK,EAAC,WAAW;EAACC,GAAG,EAAC;;;EACtBD,KAAK,EAAC;AAAe;;EAMnBA,KAAK,EAAC;AAAa;;EACjBA,KAAK,EAAC;AAAW;;EAEdA,KAAK,EAAC;AAAK;;EAEdA,KAAK,EAAC;AAAkB;;EAErBA,KAAK,EAAC;AAAK;;EAMpBA,KAAK,EAAC;AAAW;;EAeVA,KAAK,EAAC;AAAU;;EAChBA,KAAK,EAAC;AAAY;;EAClBA,KAAK,EAAC;AAAQ;;EAAyBA,KAAK,EAAC;AAAK;;;;;uBAvChEE,mBAAA,CAoDM,OApDNC,UAoDM,GAnDJC,mBAAA,CAmBM,OAnBNC,UAmBM,GAlBJD,mBAAA,CAA8C,OAA9CE,UAA8C,+BAC9CF,mBAAA,CAgBM,OAhBNG,UAgBM,G,0BAfJH,mBAAA,CAAmB,YAAf,YAAU,qB,0BACdA,mBAAA,CAGM;IAHDJ,KAAK,EAAC;EAAe,IACxBI,mBAAA,CAA6C;IAAxCJ,KAAK,EAAC;EAA2B,I,iBAAO,cAE/C,E,qBACAI,mBAAA,CASM,OATNI,UASM,GARJJ,mBAAA,CAGM,OAHNK,UAGM,G,0BAFJL,mBAAA,CAAiB,cAAX,MAAI,qBACVA,mBAAA,CAA4C,QAA5CM,UAA4C,EAAAC,gBAAA,CAAvBC,KAAA,CAAAC,MAAM,CAACC,MAAM,iB,GAEpCV,mBAAA,CAGM,OAHNW,UAGM,G,0BAFJX,mBAAA,CAAiB,cAAX,MAAI,qBACVA,mBAAA,CAA4C,QAA5CY,UAA4C,EAAAL,gBAAA,CAAvBM,QAAA,CAAAC,aAAa,iB,SAM1Cd,mBAAA,CA6BM,OA7BNe,WA6BM,G,0BA5BJf,mBAAA,CAA0B,YAAtB,mBAAiB,qBACrBA,mBAAA,CA0BQ,gB,0BAzBNA,mBAAA,CASQ,gBARNA,mBAAA,CAOK,aANHA,mBAAA,CAAa,YAAT,MAAI,GACRA,mBAAA,CAAa,YAAT,MAAI,GACRA,mBAAA,CAAoB,YAAhB,aAAW,GACfA,mBAAA,CAAgB,YAAZ,SAAO,GACXA,mBAAA,CAAa,YAAT,MAAI,GACRA,mBAAA,CAAa,YAAT,MAAI,E,uBAGZA,mBAAA,CAcQ,iB,kBAbNF,mBAAA,CASKkB,SAAA,QAAAC,WAAA,CATuBJ,QAAA,CAAAK,cAAc,GAA9BC,IAAI,EAAEC,KAAK;yBAAvBtB,mBAAA,CASK;MATwCuB,GAAG,EAAED;IAAK,IACrDpB,mBAAA,CAAyC,MAAzCsB,WAAyC,EAAAf,gBAAA,CAAjBY,IAAI,CAACI,IAAI,kBACjCvB,mBAAA,CAA2C,MAA3CwB,WAA2C,EAAAjB,gBAAA,CAAjBY,IAAI,CAACM,IAAI,kBACnCzB,mBAAA,CAAuF,MAAvF0B,WAAuF,G,kCAAjEP,IAAI,CAACQ,MAA
{"ast":null,"code":"export default {\n  props: ['flow'],\n  computed: {\n    // 排序（高流量在前）\n    sortedFlow() {\n      if (!this.flow) return [];\n      return [...this.flow].sort((a, b) => b.bytes - a.bytes);\n    },\n    // 总流量\n    totalBytes() {\n      if (!this.flow) return 0;\n      return this.flow.reduce((sum, i) => sum + (i.bytes || 0), 0);\n    },\n    // 最大流量 IP\n    maxIp() {\n      if (!this.flow || this.flow.length === 0) return '-';\n      const max = this.sortedFlow[0];\n      return max ? max.src_ip : '-';\n    }\n  }\n};","map":{"version":3,"names":["props","computed","sortedFlow","flow","sort","a","b","bytes","totalBytes","reduce","sum","i","maxIp","length","max","src_ip"],"sources":["/home/zcz/桌面/smartcampus/frontend/src/components/Realtime.vue"],"sourcesContent":["<template>\n  <div class=\"realtime\">\n    <h2>⚡ 实时流量监控</h2>\n\n    <div class=\"stats\">\n      <div class=\"card\">\n        <div class=\"title\">在线IP数</div>\n        <div class=\"value\">{{ flow.length }}</div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"title\">总流量</div>\n        <div class=\"value\">{{ totalBytes }}</div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"title\">最大流量IP</div>\n        <div class=\"value\">{{ maxIp }}</div>\n      </div>\n    </div>\n\n    <div class=\"table\">\n      <div class=\"row header\">\n        <div>源IP</div>\n        <div>流量(bytes)</div>\n        <div>状态</div>\n      </div>\n\n      <div\n        class=\"row\"\n        v-for=\"item in sortedFlow\"\n        :key=\"item.src_ip\"\n        :class=\"{ danger: item.bytes > 800 }\"\n      >\n        <div>{{ item.src_ip }}</div>\n        <div>{{ item.bytes }}</div>\n        <div>\n          <span v-if=\"item.bytes > 800\" class=\"warn\">⚠ 异常</span>\n          <span v-else class=\"ok\">正常</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  props: ['flow'],\n\n  computed: {\n    // 排序（高流量在前）\n    sortedFlow() {\n      if (!this.flow) return []\n      return [...this.flow].sort((a, b) => b.bytes - a.bytes)\n    },\n\n    // 总流量\n    totalBytes() {\n      if (!this.flow) return 0\n      return this.flow.reduce((sum, i) => sum + (i.bytes || 0), 0)\n    },\n\n    // 最大流量 IP\n    maxIp() {\n      if (!this.flow || this.flow.length === 0) return '-'\n      const max = this.sortedFlow[0]\n      return max ? max.src_ip : '-'\n    }\n  }\n}\n</script>\n\n<style scoped>\n.realtime {\n  padding: 10px;\n}\n\n.stats {\n  display: flex;\n  gap: 15px;\n  margin-bottom: 20px;\n}\n\n.card {\n  flex: 1;\n  background: #0f172a;\n  padding: 15px;\n  border-radius: 10px;\n  text-align: center;\n}\n\n.title {\n  font-size: 14px;\n  color: #94a3b8;\n}\n\n.value {\n  font-size: 22px;\n  margin-top: 8px;\n  color: #38bdf8;\n}\n\n.table {\n  background: #020617;\n  border-radius: 10px;\n  overflow: hidden;\n}\n\n.row {\n  display: grid;\n  grid-template-columns: 1fr 1fr 1fr;\n  padding: 10px;\n  border-bottom: 1px solid #1e293b;\n}\n\n.row.header {\n  background: #0f172a;\n  font-weight: bold;\n}\n\n.row.danger {\n  background: rgba(220, 38, 38, 0.15);\n}\n\n.warn {\n  color: #ef4444;\n}\n\n.ok {\n  color: #22c55e;\n}\n</style>"],"mappings":"AA8CA,eAAe;EACbA,KAAK,EAAE,CAAC,MAAM,CAAC;EAEfC,QAAQ,EAAE;IACR;IACAC,UAAUA,CAAA,EAAG;MACX,IAAI,CAAC,IAAI,CAACC,IAAI,EAAE,OAAO,EAAC;MACxB,OAAO,CAAC,GAAG,IAAI,CAACA,IAAI,CAAC,CAACC,IAAI,CAAC,CAACC,CAAC,EAAEC,CAAC,KAAKA,CAAC,CAACC,KAAI,GAAIF,CAAC,CAACE,KAAK;IACxD,CAAC;IAED;IACAC,UAAUA,CAAA,EAAG;MACX,IAAI,CAAC,IAAI,CAACL,IAAI,EAAE,OAAO;MACvB,OAAO,IAAI,CAACA,IAAI,CAACM,MAAM,CAAC,CAACC,GAAG,EAAEC,CAAC,KAAKD,GAAE,IAAKC,CAAC,CAACJ,KAAI,IAAK,CAAC,CAAC,EAAE,CAAC;IAC7D,CAAC;IAED;IACAK,KAAKA,CAAA,EAAG;MACN,IAAI,CAAC,IAAI,CAACT,IAAG,IAAK,IAAI,CAACA,IAAI,CAACU,MAAK,KAAM,CAAC,EAAE,OAAO,GAAE;MACnD,MAAMC,GAAE,GAAI,IAAI,CAACZ,UAAU,CAAC,CAAC;MAC7B,OAAOY,GAAE,GAAIA,GAAG,CAACC,MAAK,GAAI,GAAE;IAC9B;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
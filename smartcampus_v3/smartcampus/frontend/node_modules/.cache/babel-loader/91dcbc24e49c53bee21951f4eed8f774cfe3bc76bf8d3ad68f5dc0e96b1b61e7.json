{"ast":null,"code":"// 引入对应的五个子组件\nimport Dashboard from './components/Dashboard.vue';\nimport Realtime from './components/Realtime.vue';\nimport History from './components/History.vue';\nimport Rank from './components/Rank.vue';\nimport Alert from './components/Alert.vue';\nexport default {\n  name: 'App',\n  components: {\n    dashboard: Dashboard,\n    realtime: Realtime,\n    history: History,\n    rank: Rank,\n    alert: Alert\n  },\n  data() {\n    return {\n      current: 'realtime',\n      // 默认显示实时流量页\n      nowTime: '',\n      flow: [],\n      // 当前秒级实时数据\n      history: [],\n      // 历史数据队列\n      ws: null,\n      menu: [{\n        key: 'dashboard',\n        label: '数据总览'\n      }, {\n        key: 'realtime',\n        label: '实时流量'\n      }, {\n        key: 'history',\n        label: '历史记录'\n      }, {\n        key: 'rank',\n        label: '流量排行'\n      }, {\n        key: 'alert',\n        label: '异常告警'\n      }]\n    };\n  },\n  computed: {\n    currentTitle() {\n      const map = {\n        dashboard: '数据总览',\n        realtime: '实时流量监控',\n        history: '历史流记录检索',\n        rank: '全网流量排行',\n        alert: '安全态势感知与告警'\n      };\n      return map[this.current];\n    }\n  },\n  methods: {\n    switchPage(key) {\n      this.current = key;\n    },\n    connectWS() {\n      // 连接 Python 后端\n      this.ws = new WebSocket(\"ws://localhost:8000/ws/flow\");\n      this.ws.onmessage = event => {\n        const data = JSON.parse(event.data);\n        this.flow = data;\n\n        // 将新数据加入历史队列，保留最近 100 条用于历史分析\n        data.forEach(item => {\n          this.history.unshift({\n            ...item,\n            time: new Date().toLocaleTimeString()\n          });\n        });\n        if (this.history.length > 100) {\n          this.history = this.history.slice(0, 100);\n        }\n      };\n      this.ws.onclose = () => {\n        console.warn(\"WebSocket 断开，2秒后尝试重连...\");\n        setTimeout(() => {\n          this.connectWS();\n        }, 2000);\n      };\n    },\n    updateTime() {\n      this.nowTime = new Date().toLocaleString();\n    }\n  },\n  mounted() {\n    this.connectWS();\n    this.updateTime();\n    setInterval(this.updateTime, 1000);\n  }\n};","map":{"version":3,"names":["Dashboard","Realtime","History","Rank","Alert","name","components","dashboard","realtime","history","rank","alert","data","current","nowTime","flow","ws","menu","key","label","computed","currentTitle","map","methods","switchPage","connectWS","WebSocket","onmessage","event","JSON","parse","forEach","item","unshift","time","Date","toLocaleTimeString","length","slice","onclose","console","warn","setTimeout","updateTime","toLocaleString","mounted","setInterval"],"sources":["/home/zcz/桌面/smartcampus/frontend/src/App.vue"],"sourcesContent":["<template>\n  <div class=\"app\">\n    <div class=\"sidebar\">\n      <h2 class=\"logo\">Net Monitor</h2>\n      <div\n        v-for=\"item in menu\"\n        :key=\"item.key\"\n        :class=\"['menu-item', { active: current === item.key }]\"\n        @click=\"switchPage(item.key)\"\n      >\n        {{ item.label }}\n      </div>\n    </div>\n\n    <div class=\"content\">\n      <div class=\"topbar\">\n        <div class=\"title\">{{ currentTitle }}</div>\n        <div class=\"time\">{{ nowTime }}</div>\n      </div>\n\n      <div class=\"page\">\n        <keep-alive>\n          <component\n            :is=\"current\"\n            :flow=\"flow\"\n            :history=\"history\"\n          />\n        </keep-alive>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\n// 引入对应的五个子组件\nimport Dashboard from './components/Dashboard.vue'\nimport Realtime from './components/Realtime.vue'\nimport History from './components/History.vue'\nimport Rank from './components/Rank.vue'\nimport Alert from './components/Alert.vue'\n\nexport default {\n  name: 'App',\n  components: {\n    dashboard: Dashboard,\n    realtime: Realtime,\n    history: History,\n    rank: Rank,\n    alert: Alert\n  },\n  data() {\n    return {\n      current: 'realtime', // 默认显示实时流量页\n      nowTime: '',\n      flow: [], // 当前秒级实时数据\n      history: [], // 历史数据队列\n      ws: null,\n      menu: [\n        { key: 'dashboard', label: '数据总览' },\n        { key: 'realtime', label: '实时流量' },\n        { key: 'history', label: '历史记录' },\n        { key: 'rank', label: '流量排行' },\n        { key: 'alert', label: '异常告警' }\n      ]\n    }\n  },\n  computed: {\n    currentTitle() {\n      const map = {\n        dashboard: '数据总览',\n        realtime: '实时流量监控',\n        history: '历史流记录检索',\n        rank: '全网流量排行',\n        alert: '安全态势感知与告警'\n      }\n      return map[this.current]\n    }\n  },\n  methods: {\n    switchPage(key) {\n      this.current = key\n    },\n    connectWS() {\n      // 连接 Python 后端\n      this.ws = new WebSocket(\"ws://localhost:8000/ws/flow\")\n      \n      this.ws.onmessage = (event) => {\n        const data = JSON.parse(event.data)\n        this.flow = data\n        \n        // 将新数据加入历史队列，保留最近 100 条用于历史分析\n        data.forEach(item => {\n          this.history.unshift({\n            ...item,\n            time: new Date().toLocaleTimeString()\n          })\n        })\n        if (this.history.length > 100) {\n          this.history = this.history.slice(0, 100)\n        }\n      }\n\n      this.ws.onclose = () => {\n        console.warn(\"WebSocket 断开，2秒后尝试重连...\")\n        setTimeout(() => { this.connectWS() }, 2000)\n      }\n    },\n    updateTime() {\n      this.nowTime = new Date().toLocaleString()\n    }\n  },\n  mounted() {\n    this.connectWS()\n    this.updateTime()\n    setInterval(this.updateTime, 1000)\n  }\n}\n</script>\n\n<style scoped>\n.app { display: flex; height: 100vh; background: #0f172a; color: #fff; font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif; }\n.sidebar { width: 220px; background: #1e293b; padding: 20px 15px; border-right: 1px solid #334155; }\n.logo { color: #38bdf8; margin-bottom: 30px; text-align: center; font-size: 24px; font-weight: bold; }\n.menu-item { padding: 12px 20px; margin-bottom: 10px; cursor: pointer; border-radius: 8px; transition: all 0.3s; font-size: 15px; }\n.menu-item:hover { background: #334155; }\n.menu-item.active { background: #38bdf8; color: #0f172a; font-weight: bold; }\n.content { flex: 1; display: flex; flex-direction: column; overflow: hidden; }\n.topbar { height: 60px; background: #1e293b; display: flex; justify-content: space-between; align-items: center; padding: 0 25px; border-bottom: 1px solid #334155; }\n.title { font-size: 18px; font-weight: 600; color: #f8fafc; }\n.time { color: #94a3b8; font-size: 14px; }\n.page { flex: 1; padding: 20px; overflow: auto; background: #0f172a; }\n</style>"],"mappings":"AAkCA;AACA,OAAOA,SAAQ,MAAO,4BAA2B;AACjD,OAAOC,QAAO,MAAO,2BAA0B;AAC/C,OAAOC,OAAM,MAAO,0BAAyB;AAC7C,OAAOC,IAAG,MAAO,uBAAsB;AACvC,OAAOC,KAAI,MAAO,wBAAuB;AAEzC,eAAe;EACbC,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IACVC,SAAS,EAAEP,SAAS;IACpBQ,QAAQ,EAAEP,QAAQ;IAClBQ,OAAO,EAAEP,OAAO;IAChBQ,IAAI,EAAEP,IAAI;IACVQ,KAAK,EAAEP;EACT,CAAC;EACDQ,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,UAAU;MAAE;MACrBC,OAAO,EAAE,EAAE;MACXC,IAAI,EAAE,EAAE;MAAE;MACVN,OAAO,EAAE,EAAE;MAAE;MACbO,EAAE,EAAE,IAAI;MACRC,IAAI,EAAE,CACJ;QAAEC,GAAG,EAAE,WAAW;QAAEC,KAAK,EAAE;MAAO,CAAC,EACnC;QAAED,GAAG,EAAE,UAAU;QAAEC,KAAK,EAAE;MAAO,CAAC,EAClC;QAAED,GAAG,EAAE,SAAS;QAAEC,KAAK,EAAE;MAAO,CAAC,EACjC;QAAED,GAAG,EAAE,MAAM;QAAEC,KAAK,EAAE;MAAO,CAAC,EAC9B;QAAED,GAAG,EAAE,OAAO;QAAEC,KAAK,EAAE;MAAO;IAElC;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,YAAYA,CAAA,EAAG;MACb,MAAMC,GAAE,GAAI;QACVf,SAAS,EAAE,MAAM;QACjBC,QAAQ,EAAE,QAAQ;QAClBC,OAAO,EAAE,SAAS;QAClBC,IAAI,EAAE,QAAQ;QACdC,KAAK,EAAE;MACT;MACA,OAAOW,GAAG,CAAC,IAAI,CAACT,OAAO;IACzB;EACF,CAAC;EACDU,OAAO,EAAE;IACPC,UAAUA,CAACN,GAAG,EAAE;MACd,IAAI,CAACL,OAAM,GAAIK,GAAE;IACnB,CAAC;IACDO,SAASA,CAAA,EAAG;MACV;MACA,IAAI,CAACT,EAAC,GAAI,IAAIU,SAAS,CAAC,6BAA6B;MAErD,IAAI,CAACV,EAAE,CAACW,SAAQ,GAAKC,KAAK,IAAK;QAC7B,MAAMhB,IAAG,GAAIiB,IAAI,CAACC,KAAK,CAACF,KAAK,CAAChB,IAAI;QAClC,IAAI,
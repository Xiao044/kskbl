{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  name: 'Alert',\n  props: {\n    // 监听实时流量，用于触发告警\n    flow: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      alerts: [],\n      radarInstance: null,\n      threatStats: {\n        'DDoS攻击': 0,\n        '端口扫描': 0,\n        '蠕虫病毒': 0,\n        '异常高频访问': 0,\n        '钓鱼/恶意伪造': 0\n      }\n    };\n  },\n  computed: {\n    reversedAlerts() {\n      return [...this.alerts].reverse();\n    },\n    highRiskCount() {\n      return this.alerts.filter(a => a.level === 'high').length;\n    }\n  },\n  watch: {\n    flow: {\n      handler(newData) {\n        this.detectThreats(newData);\n      },\n      deep: true\n    }\n  },\n  mounted() {\n    this.radarInstance = echarts.init(this.$refs.radarChart);\n    this.updateRadarChart();\n    window.addEventListener('resize', this.resizeChart);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.resizeChart);\n    if (this.radarInstance) this.radarInstance.dispose();\n  },\n  methods: {\n    // 基于前端的简易入侵检测系统 (IDS) 模拟\n    detectThreats(data) {\n      const now = new Date().toLocaleTimeString();\n      let hasNewThreat = false;\n      data.forEach(item => {\n        // 规则1：如果单IP在一秒内发包数过高，判定为 DDoS 或 洪泛攻击\n        if (item.packets > 500) {\n          this.alerts.push({\n            time: now,\n            type: '疑似 DDoS 攻击 (洪泛)',\n            src_ip: item.src_ip,\n            geo_loc: item.geo_loc,\n            target: '多协议/全量',\n            level: 'high'\n          });\n          this.threatStats['DDoS攻击']++;\n          hasNewThreat = true;\n        }\n        // 规则2：如果单IP同时使用多个协议且流量异常，疑似端口扫描\n        else if (item.protocols.length >= 3 && item.packets > 100) {\n          this.alerts.push({\n            time: now,\n            type: '暴力端口扫描',\n            src_ip: item.src_ip,\n            geo_loc: item.geo_loc,\n            target: item.protocols.join(','),\n            level: 'medium'\n          });\n          this.threatStats['端口扫描']++;\n          hasNewThreat = true;\n        }\n      });\n\n      // 保持日志最多保留 50 条\n      if (this.alerts.length > 50) this.alerts = this.alerts.slice(-50);\n      if (hasNewThreat) this.updateRadarChart();\n    },\n    updateRadarChart() {\n      const option = {\n        title: {\n          text: '攻击类型雷达分布图',\n          textStyle: {\n            color: '#e2e8f0',\n            fontSize: 16\n          }\n        },\n        tooltip: {},\n        radar: {\n          indicator: [{\n            name: 'DDoS攻击',\n            max: Math.max(10, this.threatStats['DDoS攻击'] * 2)\n          }, {\n            name: '端口扫描',\n            max: Math.max(10, this.threatStats['端口扫描'] * 2)\n          }, {\n            name: '蠕虫病毒',\n            max: 10\n          }, {\n            name: '异常高频访问',\n            max: 10\n          }, {\n            name: '钓鱼/伪造',\n            max: 10\n          }],\n          splitArea: {\n            areaStyle: {\n              color: ['rgba(239, 68, 68, 0.1)', 'rgba(239, 68, 68, 0.05)', 'rgba(30, 41, 59, 0.5)']\n            }\n          },\n          axisName: {\n            color: '#94a3b8'\n          }\n        },\n        series: [{\n          name: '威胁统计',\n          type: 'radar',\n          data: [{\n            value: [this.threatStats['DDoS攻击'], this.threatStats['端口扫描'], this.threatStats['蠕虫病毒'], this.threatStats['异常高频访问'], this.threatStats['钓鱼/恶意伪造']],\n            name: '威胁次数'\n          }],\n          itemStyle: {\n            color: '#f87171'\n          },\n          areaStyle: {\n            color: 'rgba(248, 113, 113, 0.4)'\n          }\n        }]\n      };\n      this.radarInstance.setOption(option);\n    },\n    resizeChart() {\n      if (this.radarInstance) this.radarInstance.resize();\n    }\n  }\n};","map":{"version":3,"names":["echarts","name","props","flow","type","Array","default","data","alerts","radarInstance","threatStats","computed","reversedAlerts","reverse","highRiskCount","filter","a","level","length","watch","handler","newData","detectThreats","deep","mounted","init","$refs","radarChart","updateRadarChart","window","addEventListener","resizeChart","beforeUnmount","removeEventListener","dispose","methods","now","Date","toLocaleTimeString","hasNewThreat","forEach","item","packets","push","time","src_ip","geo_loc","target","protocols","join","slice","option","title","text","textStyle","color","fontSize","tooltip","radar","indicator","max","Math","splitArea","areaStyle","axisName","series","value","itemStyle","setOption","resize"],"sources":["/home/zcz/桌面/smartcampus/frontend/src/components/Alert.vue"],"sourcesContent":["<template>\n  <div class=\"alert-container\">\n    <div class=\"charts-row\">\n      <div class=\"chart-box\" ref=\"radarChart\"></div>\n      <div class=\"alert-summary\">\n        <h3>动态威胁感知引擎状态</h3>\n        <div class=\"engine-status\">\n          <div class=\"status-indicator scanning\"></div>\n          安全规则匹配中...\n        </div>\n        <div class=\"alert-stats\">\n          <div class=\"stat-item\">\n            <span>拦截总数</span>\n            <span class=\"num\">{{ alerts.length }}</span>\n          </div>\n          <div class=\"stat-item danger\">\n            <span>高危警告</span>\n            <span class=\"num\">{{ highRiskCount }}</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"table-box\">\n      <h3>实时安全告警日志 (SecLog)</h3>\n      <table>\n        <thead>\n          <tr>\n            <th>告警时间</th>\n            <th>威胁类型</th>\n            <th>攻击源 IP (溯源)</th>\n            <th>目标协议/业务</th>\n            <th>危险等级</th>\n            <th>当前状态</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr v-for=\"(item, index) in reversedAlerts\" :key=\"index\">\n            <td class=\"time-col\">{{ item.time }}</td>\n            <td class=\"threat-col\">{{ item.type }}</td>\n            <td class=\"ip-col\">{{ item.src_ip }} <span class=\"geo\">({{ item.geo_loc }})</span></td>\n            <td>{{ item.target }}</td>\n            <td>\n              <span :class=\"['risk-badge', item.level]\">{{ item.level === 'high' ? '高危' : '中危' }}</span>\n            </td>\n            <td class=\"status-col\">已拦截/记录</td>\n          </tr>\n          <tr v-if=\"alerts.length === 0\">\n            <td colspan=\"6\" class=\"empty-text\">当前网络环境安全，未检测到异常攻击行为</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts';\n\nexport default {\n  name: 'Alert',\n  props: {\n    // 监听实时流量，用于触发告警\n    flow: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      alerts: [],\n      radarInstance: null,\n      threatStats: {\n        'DDoS攻击': 0,\n        '端口扫描': 0,\n        '蠕虫病毒': 0,\n        '异常高频访问': 0,\n        '钓鱼/恶意伪造': 0\n      }\n    }\n  },\n  computed: {\n    reversedAlerts() {\n      return [...this.alerts].reverse();\n    },\n    highRiskCount() {\n      return this.alerts.filter(a => a.level === 'high').length;\n    }\n  },\n  watch: {\n    flow: {\n      handler(newData) {\n        this.detectThreats(newData);\n      },\n      deep: true\n    }\n  },\n  mounted() {\n    this.radarInstance = echarts.init(this.$refs.radarChart);\n    this.updateRadarChart();\n    window.addEventListener('resize', this.resizeChart);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.resizeChart);\n    if (this.radarInstance) this.radarInstance.dispose();\n  },\n  methods: {\n    // 基于前端的简易入侵检测系统 (IDS) 模拟\n    detectThreats(data) {\n      const now = new Date().toLocaleTimeString();\n      let hasNewThreat = false;\n\n      data.forEach(item => {\n        // 规则1：如果单IP在一秒内发包数过高，判定为 DDoS 或 洪泛攻击\n        if (item.packets > 500) {\n          this.alerts.push({\n            time: now, type: '疑似 DDoS 攻击 (洪泛)', src_ip: item.src_ip, \n            geo_loc: item.geo_loc, target: '多协议/全量', level: 'high'\n          });\n          this.threatStats['DDoS攻击']++;\n          hasNewThreat = true;\n        }\n        // 规则2：如果单IP同时使用多个协议且流量异常，疑似端口扫描\n        else if (item.protocols.length >= 3 && item.packets > 100) {\n          this.alerts.push({\n            time: now, type: '暴力端口扫描', src_ip: item.src_ip, \n            geo_loc: item.geo_loc, target: item.protocols.join(','), level: 'medium'\n          });\n          this.threatStats['端口扫描']++;\n          hasNewThreat = true;\n        }\n      });\n\n      // 保持日志最多保留 50 条\n      if (this.alerts.length > 50) this.alerts = this.alerts.slice(-50);\n      \n      if (hasNewThreat) this.updateRadarChart();\n    },\n    updateRadarChart() {\n      const option = {\n        title: { text: '攻击类型雷达分布图', textStyle: { color: '#e2e8f0', fontSize: 16 } },\n        tooltip: {},\n        radar: {\n          indicator: [\n            { name: 'DDoS攻击', max: Math.max(10, this.threatStats['DDoS攻击'] * 2) },\n            { name: '端口扫描', max: Math.max(10, this.threatStats['端口扫描'] * 2) },\n            { name: '蠕虫病毒', max: 10 },\n            { name: '异常高频访问', max: 10 },\n            { name: '钓鱼/伪造', max: 10 }\n          ],\n          splitArea: { areaStyle: { color: ['rgba(239, 68, 68, 0.1)', 'rgba(239, 68, 68, 0.05)', 'rgba(30, 41, 59, 0.5)'] } },\n          axisName: { color: '#94a3b8' }\n        },\n        series: [{\n          name: '威胁统计',\n          type: 'radar',\n          data: [{\n            value: [this.threatStats['DDoS攻击'], this.threatStats['端口扫描'], this.threatStats['蠕虫病毒'], this.threatStats['异常高频访问'], this.threatStats['钓鱼/恶意伪造']],\n            name: '威胁次数'\n          }],\n          itemStyle: { color: '#f87171' },\n          areaStyle: { color: 'rgba(248, 113, 113, 0.4)' }\n        }]\n      };\n      this.radarInstance.setOption(option);\n    },\n    resizeChart() {\n      if (this.radarInstance) this.radarInstance.resize();\n    }\n  }\n}\n</script>\n\n<style scoped>\n.alert-container { display: flex; flex-direction: column; gap: 20px; height: 100%; }\n.charts-row { display: flex; height: 280px; gap: 20px; }\n.chart-box { flex: 1.5; background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }\n.alert-summary { flex: 1; background: #1e293b; border-radius: 12px; padding: 25px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); display: flex; flex-direction: column; }\n.alert-summary h3 { margin-top: 0; color: #e2e8f0; border-bottom: 1px solid #334155; padding-bottom: 10px; }\n\n.engine-status { color: #a3e635; display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-weight: bold; }\n.status-indicator { width: 12px; height: 12px; border-radius: 50%; background: #a3e635; box-shadow: 0 0 8px #a3e635; }\n.scanning { animation: pulse 1.5s infinite; }\n@keyframes pulse { 0% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.2); } 100% { opacity: 1; transform: scale(1); } }\n\n.alert-stats { display: flex; gap: 20px; }\n.stat-item { background: #0f172a; padding: 15px; border-radius: 8px; flex: 1; text-align: center; border: 1px solid #334155; }\n.stat-item span { display: block; color: #94a3b8; font-size: 14px; }\n.stat-item .num { font-size: 28px; font-weight: bold; color: #38bdf8; margin-top: 5px; }\n.stat-item.danger { border-color: #7f1d1d; background: #450a0a; }\n.stat-item.danger .num { color: #f87171; }\n\n.table-box { flex: 1; background: #1e293b; border-radius: 12px; padding: 20px; overflow-y: auto; }\n.table-box h3 { margin-top: 0; margin-bottom: 15px; color: #f87171; }\ntable { width: 100%; border-collapse: collapse; }\nth, td { padding: 12px; text-align: left; border-bottom: 1px solid #334155; font-size: 14px; }\nth { color: #94a3b8; font-weight: 500; position: sticky; top: 0; background: #1e293b; }\n.time-col { color: #cbd5e1; }\n.threat-col { color: #f87171; font-weight: bold; }\n.ip-col { color: #e2e8f0; font-family: monospace; }\n.geo { color: #64748b; font-size: 12px; font-family: sans-serif; }\n.risk-badge { padding: 3px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; }\n.risk-badge.high { background: #7f1d1d; color: #fca5a5; }\n.risk-badge.medium { background: #78350f; color: #fcd34d; }\n.status-col { color: #22c55e; }\n.empty-text { text-align: center; color: #64748b; padding: 30px !important; }\n</style>"],"mappings":"AAyDA,OAAO,KAAKA,OAAM,MAAO,SAAS;AAElC,eAAe;EACbC,IAAI,EAAE,OAAO;EACbC,KAAK,EAAE;IACL;IACAC,IAAI,EAAE;MACJC,IAAI,EAAEC,KAAK;MACXC,OAAO,EAAEA,CAAA,KAAM;IACjB;EACF,CAAC;EACDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAE,EAAE;MACVC,aAAa,EAAE,IAAI;MACnBC,WAAW,EAAE;QACX,QAAQ,EAAE,CAAC;QACX,MAAM,EAAE,CAAC;QACT,MAAM,EAAE,CAAC;QACT,QAAQ,EAAE,CAAC;QACX,SAAS,EAAE;MACb;IACF;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,cAAcA,CAAA,EAAG;MACf,OAAO,CAAC,GAAG,IAAI,CAACJ,MAAM,CAAC,CAACK,OAAO,CAAC,CAAC;IACnC,CAAC;IACDC,aAAaA,CAAA,EAAG;MACd,OAAO,IAAI,CAACN,MAAM,CAACO,MAAM,CAACC,CAAA,IAAKA,CAAC,CAACC,KAAI,KAAM,MAAM,CAAC,CAACC,MAAM;IAC3D;EACF,CAAC;EACDC,KAAK,EAAE;IACLhB,IAAI,EAAE;MACJiB,OAAOA,CAACC,OAAO,EAAE;QACf,IAAI,CAACC,aAAa,CAACD,OAAO,CAAC;MAC7B,CAAC;MACDE,IAAI,EAAE;IACR;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACf,aAAY,GAAIT,OAAO,CAACyB,IAAI,CAAC,IAAI,CAACC,KAAK,CAACC,UAAU,CAAC;IACxD,IAAI,CAACC,gBAAgB,CAAC,CAAC;IACvBC,MAAM,CAACC,gBAAgB,CAAC,QAAQ,EAAE,IAAI,CAACC,WAAW,CAAC;EACrD,CAAC;EACDC,aAAaA,CAAA,EAAG;IACdH,MAAM,CAACI,mBAAmB,CAAC,QAAQ,EAAE,IAAI,CAACF,WAAW,CAAC;IACtD,IAAI,IAAI,CAACtB,aAAa,EAAE,IAAI,CAACA,aAAa,CAACyB,OAAO,CAAC,CAAC;EACtD,CAAC;EACDC,OAAO,EAAE;IACP;IACAb,aAAaA,CAACf,IAAI,EAAE;MAClB,MAAM6B,GAAE,GAAI,IAAIC,IAAI,CAAC,CAAC,CAACC,kBAAkB,CAAC,CAAC;MAC3C,IAAIC,YAAW,GAAI,KAAK;MAExBhC,IAAI,CAACiC,OAAO,CAACC,IAAG,IAAK;QACnB;QACA,IAAIA,IAAI,CAACC,OAAM,GAAI,GAAG,EAAE;UACtB,IAAI,CAAClC,MAAM,CAACmC,IAAI,CAAC;YACfC,IAAI,EAAER,GAAG;YAAEhC,IAAI,EAAE,iBAAiB;YAAEyC,MAAM,EAAEJ,IAAI,CAACI,MAAM;YACvDC,OAAO,EAAEL,IAAI,CAACK,OAAO;YAAEC,MAAM,EAAE,QAAQ;YAAE9B,KAAK,EAAE;UAClD,CAAC,CAAC;UACF,IAAI,CAACP,WAAW,CAAC,QAAQ,CAAC,EAAE;UAC5B6B,YAAW,GAAI,IAAI;QACrB;QACA;QAAA,KACK,IAAIE,IAAI,CAACO,SAAS,CAAC9B,MAAK,IAAK,KAAKuB,IAAI,CAA
{"ast":null,"code":"export default {\n  name: 'History',\n  props: {\n    // 接收过去一段时间的流记录\n    history: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      searchQuery: ''\n    };\n  },\n  computed: {\n    // 核心检索引擎：根据输入框实时过滤\n    filteredHistory() {\n      if (!this.searchQuery) return this.history;\n      const lowerQuery = this.searchQuery.toLowerCase();\n      return this.history.filter(item => {\n        const ipMatch = item.src_ip.toLowerCase().includes(lowerQuery);\n        const geoMatch = item.geo_loc.toLowerCase().includes(lowerQuery);\n        const protoMatch = item.protocols.some(p => p.toLowerCase().includes(lowerQuery));\n        return ipMatch || geoMatch || protoMatch;\n      });\n    }\n  },\n  methods: {\n    formatBytes(bytes) {\n      if (bytes === 0) return '0 B';\n      const k = 1024;\n      const sizes = ['B', 'KB', 'MB', 'GB'];\n      const i = Math.floor(Math.log(bytes) / Math.log(k));\n      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];\n    }\n  }\n};","map":{"version":3,"names":["name","props","history","type","Array","default","data","searchQuery","computed","filteredHistory","lowerQuery","toLowerCase","filter","item","ipMatch","src_ip","includes","geoMatch","geo_loc","protoMatch","protocols","some","p","methods","formatBytes","bytes","k","sizes","i","Math","floor","log","parseFloat","pow","toFixed"],"sources":["/home/zcz/桌面/smartcampus/frontend/src/components/History.vue"],"sourcesContent":["<template>\n  <div class=\"history-container\">\n    <div class=\"filter-box\">\n      <div class=\"search-group\">\n        <label>微观流检索 (源IP/协议/地理位置)：</label>\n        <input \n          type=\"text\" \n          v-model=\"searchQuery\" \n          placeholder=\"例如输入 '10.0' 或 'HTTP' 或 '苏州'\" \n          class=\"search-input\"\n        />\n      </div>\n      <div class=\"stats\">\n        当前检索结果：<span class=\"highlight\">{{ filteredHistory.length }}</span> 条记录\n      </div>\n    </div>\n\n    <div class=\"table-box\">\n      <table>\n        <thead>\n          <tr>\n            <th>捕获时间</th>\n            <th>源 IP 地址</th>\n            <th>地理溯源位置</th>\n            <th>吞吐量 (Bytes)</th>\n            <th>数据包量 (Packets)</th>\n            <th>应用/协议</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr v-for=\"(item, index) in filteredHistory\" :key=\"index\">\n            <td class=\"time-col\">{{ item.time }}</td>\n            <td class=\"ip-col\">{{ item.src_ip }}</td>\n            <td>{{ item.geo_loc }}</td>\n            <td>{{ formatBytes(item.bytes) }}</td>\n            <td>{{ item.packets }}</td>\n            <td>\n              <span class=\"tag\" v-for=\"p in item.protocols\" :key=\"p\">{{ p }}</span>\n            </td>\n          </tr>\n          <tr v-if=\"filteredHistory.length === 0\">\n            <td colspan=\"6\" class=\"empty-text\">未匹配到符合条件的流记录</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'History',\n  props: {\n    // 接收过去一段时间的流记录\n    history: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      searchQuery: ''\n    }\n  },\n  computed: {\n    // 核心检索引擎：根据输入框实时过滤\n    filteredHistory() {\n      if (!this.searchQuery) return this.history;\n      const lowerQuery = this.searchQuery.toLowerCase();\n      \n      return this.history.filter(item => {\n        const ipMatch = item.src_ip.toLowerCase().includes(lowerQuery);\n        const geoMatch = item.geo_loc.toLowerCase().includes(lowerQuery);\n        const protoMatch = item.protocols.some(p => p.toLowerCase().includes(lowerQuery));\n        return ipMatch || geoMatch || protoMatch;\n      });\n    }\n  },\n  methods: {\n    formatBytes(bytes) {\n      if (bytes === 0) return '0 B';\n      const k = 1024;\n      const sizes = ['B', 'KB', 'MB', 'GB'];\n      const i = Math.floor(Math.log(bytes) / Math.log(k));\n      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];\n    }\n  }\n}\n</script>\n\n<style scoped>\n.history-container { display: flex; flex-direction: column; gap: 20px; height: 100%; }\n.filter-box { background: #1e293b; border-radius: 12px; padding: 20px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }\n.search-group label { color: #94a3b8; margin-right: 15px; font-size: 14px; }\n.search-input { background: #0f172a; border: 1px solid #334155; color: #f8fafc; padding: 10px 15px; border-radius: 6px; width: 300px; outline: none; transition: border-color 0.3s; }\n.search-input:focus { border-color: #38bdf8; }\n.stats { color: #94a3b8; font-size: 14px; }\n.highlight { color: #08ebdf; font-weight: bold; font-size: 16px; }\n\n.table-box { flex: 1; background: #1e293b; border-radius: 12px; padding: 20px; overflow-y: auto; }\ntable { width: 100%; border-collapse: collapse; }\nth, td { padding: 14px 12px; text-align: left; border-bottom: 1px solid #334155; font-size: 14px; }\nth { color: #94a3b8; font-weight: 500; position: sticky; top: 0; background: #1e293b; }\n.time-col { color: #cbd5e1; }\n.ip-col { color: #38bdf8; font-family: monospace; }\n.tag { display: inline-block; background: #334155; color: #08ebdf; padding: 3px 8px; border-radius: 4px; font-size: 12px; margin-right: 5px; }\n.empty-text { text-align: center; color: #64748b; padding: 30px !important; }\n</style>"],"mappings":"AAkDA,eAAe;EACbA,IAAI,EAAE,SAAS;EACfC,KAAK,EAAE;IACL;IACAC,OAAO,EAAE;MACPC,IAAI,EAAEC,KAAK;MACXC,OAAO,EAAEA,CAAA,KAAM;IACjB;EACF,CAAC;EACDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAE;IACf;EACF,CAAC;EACDC,QAAQ,EAAE;IACR;IACAC,eAAeA,CAAA,EAAG;MAChB,IAAI,CAAC,IAAI,CAACF,WAAW,EAAE,OAAO,IAAI,CAACL,OAAO;MAC1C,MAAMQ,UAAS,GAAI,IAAI,CAACH,WAAW,CAACI,WAAW,CAAC,CAAC;MAEjD,OAAO,IAAI,CAACT,OAAO,CAACU,MAAM,CAACC,IAAG,IAAK;QACjC,MAAMC,OAAM,GAAID,IAAI,CAACE,MAAM,CAACJ,WAAW,CAAC,CAAC,CAACK,QAAQ,CAACN,UAAU,CAAC;QAC9D,MAAMO,QAAO,GAAIJ,IAAI,CAACK,OAAO
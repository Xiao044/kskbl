lementVNode(\"span\", {\n    class: \"unit\"\n  }, \"PPS\", -1 /* CACHED */))])]), _createElementVNode(\"div\", _hoisted_7, [_cache[5] || (_cache[5] = _createElementVNode(\"div\", {\n    class: \"card-title\"\n  }, \"监测活跃大流节点\", -1 /* CACHED */)), _createElementVNode(\"div\", _hoisted_8, [_createTextVNode(_toDisplayString($options.activeNodes) + \" \", 1 /* TEXT */), _cache[4] || (_cache[4] = _createElementVNode(\"span\", {\n    class: \"unit\"\n  }, \"个\", -1 /* CACHED */))])]), _createElementVNode(\"div\", _hoisted_9, [_cache[6] || (_cache[6] = _createElementVNode(\"div\", {\n    class: \"card-title\"\n  }, \"当前主要协议\", -1 /* CACHED */)), _createElementVNode(\"div\", _hoisted_10, _toDisplayString($options.topProtocol), 1 /* TEXT */)])]), _createElementVNode(\"div\", _hoisted_11, [_createElementVNode(\"div\", _hoisted_12, null, 512 /* NEED_PATCH */)]), _createElementVNode(\"div\", _hoisted_13, [_createElementVNode(\"div\", _hoisted_14, null, 512 /* NEED_PATCH */), _cache[7] || (_cache[7] = _createStaticVNode(\"<div class=\\\"info-box half-width\\\" data-v-aae30ed8><h3 data-v-aae30ed8>全网安全态势感知概览</h3><ul class=\\\"status-list\\\" data-v-aae30ed8><li data-v-aae30ed8><span class=\\\"status-label\\\" data-v-aae30ed8>系统运行状态：</span><span class=\\\"status-value safe\\\" data-v-aae30ed8>正常抓包解析中</span></li><li data-v-aae30ed8><span class=\\\"status-label\\\" data-v-aae30ed8>当前链路带宽：</span><span class=\\\"status-value\\\" data-v-aae30ed8>10 Gbps (监测中)</span></li><li data-v-aae30ed8><span class=\\\"status-label\\\" data-v-aae30ed8>异常流量预警：</span><span class=\\\"status-value warning\\\" data-v-aae30ed8>未检测到明显 DDoS/扫描攻击</span></li><li data-v-aae30ed8><span class=\\\"status-label\\\" data-v-aae30ed8>数据接入点：</span><span class=\\\"status-value\\\" data-v-aae30ed8>核心交换机/出口网关</span></li></ul></div>\", 1))])]);\n}","map":{"version":3,"names":["class","ref","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_hoisted_3","_hoisted_4","$options","currentMbps","_hoisted_5","_hoisted_6","currentPPS","_hoisted_7","_hoisted_8","activeNodes","_hoisted_9","_hoisted_10","_toDisplayString","topProtocol","_hoisted_11","_hoisted_12","_hoisted_13","_hoisted_14"],"sources":["/home/zcz/桌面/smartcampus/frontend/src/components/Dashboard.vue"],"sourcesContent":["<template>\n  <div class=\"dashboard-container\">\n    <div class=\"stat-cards\">\n      <div class=\"card\">\n        <div class=\"card-title\">全网实时吞吐量</div>\n        <div class=\"card-value throughput\">\n          {{ currentMbps }} <span class=\"unit\">Mbps</span>\n        </div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-title\">全网实时包速率</div>\n        <div class=\"card-value pps\">\n          {{ currentPPS }} <span class=\"unit\">PPS</span>\n        </div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-title\">监测活跃大流节点</div>\n        <div class=\"card-value active-ips\">\n          {{ activeNodes }} <span class=\"unit\">个</span>\n        </div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-title\">当前主要协议</div>\n        <div class=\"card-value protocol\">\n          {{ topProtocol }}\n        </div>\n      </div>\n    </div>\n\n    <div class=\"main-chart-row\">\n      <div class=\"chart-box full-width\" ref=\"globalTrendChart\"></div>\n    </div>\n\n    <div class=\"bottom-row\">\n      <div class=\"chart-box half-width\" ref=\"globalProtocolChart\"></div>\n      <div class=\"info-box half-width\">\n        <h3>全网安全态势感知概览</h3>\n        <ul class=\"status-list\">\n          <li>\n            <span class=\"status-label\">系统运行状态：</span>\n            <span class=\"status-value safe\">正常抓包解析中</span>\n          </li>\n          <li>\n            <span class=\"status-label\">当前链路带宽：</span>\n            <span class=\"status-value\">10 Gbps (监测中)</span>\n          </li>\n          <li>\n            <span class=\"status-label\">异常流量预警：</span>\n            <span class=\"status-value warning\">未检测到明显 DDoS/扫描攻击</span>\n          </li>\n          <li>\n            <span class=\"status-label\">数据接入点：</span>\n            <span class=\"status-value\">核心交换机/出口网关</span>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts';\n\nexport default {\n  name: 'Dashboard',\n  props: {\n    // 接收 App.vue 传来的秒级实时数据\n    flow: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      trendInstance: null,\n      protocolInstance: null,\n      // 本地维护一个时间序列，用于绘制动态趋势图\n      trendData: {\n        times: [],\n        mbps: []\n      }\n    }\n  },\n  computed: {\n    // 聚合计算：总吞吐量 (Bytes 转 Mbps = Bytes * 8 / 1024 / 1024)\n    currentMbps() {\n      if (!this.flow.length) return '0.00';\n      const totalBytes = this.flow.reduce((sum, item) => sum + item.bytes, 0);\n      return (totalBytes * 8 / 1024 / 1024).toFixed(2);\n    },\n    // 聚合计算：总包数\n    currentPPS() {\n      if (!this.flow.length) return 0;\n      return this.flow.reduce((sum, item) => sum + item.packets, 0);\n    },\n    // 活跃节点数\n    activeNodes() {\n      return this.flow.length;\n    },\n    // 计算出现次数最多的协议\n    topProtocol() {\n      if (!this.flow.length) return 'N/A';\n      const count = {};\n      this.flow.forEach(item => {\n        item.protocols.forEach(p => {\n          count[p] = (count[p] || 0) + 1;\n        });\n      });\n      const sorted = Object.keys(count).sort((a, b) => count[b] - count[a]);\n      return sorted[0] || 'Unknown';\n    }\n  },\n  watch: {\n    // 每次收到新数据，更新趋势图和环形图\n    flow: {\n      handler(newData) {\n        if (newData) {\n          this.updateTrendData();\n          this.updateProtocolChart();\n        }\n      },\n      deep: true\n    }\n  },\n  mounted() {\n    this.initCharts();\n    window.addEventListener('resize', this.resizeCharts);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.resizeCharts);\n    if (this.trendInstance) this.trendInstance.dispose();\n    if (this.protocolInstance) this.protocolInstance.dispose();\n  },\n  methods: {\n    initCharts() {\n      this.trendInstance = echarts.init(this.$refs.globalTrendChart);\n      this.protocolInstance = echarts.init(this.$refs.globalProtocolChart);\n      \n      // 初始化趋势图空壳\n      this.trendInstance.setOption({\n        title: { text: '宏观网络吞吐量实时波动 (Mbps)', textStyle: { color: '#e2e8f0', fontSize: 16 } },\n        tooltip: { trigger: 'axis', axisPointer: { type: 'cross' } },\n        grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },\n        xAxis: { type: 'category', boundaryGap: false, data: [], axisLabel: { color: '#94a3b8' } },\n        yAxis: { type: 'value', axisLabel: { color: '#94a3b8' }, splitLine: { lineStyle: { color: '#334155' } } },\n        series: [{\n          name: '吞吐量',\n          type: 'line',\n          smooth: true,\n          symbol: 'none',\n          itemStyle: { color: '#08ebdf' },\n          areaStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n              { offset: 0, color: 'rgba(8, 235, 223, 0.5)' },\n              { offset: 1, color: 'rgba(8, 235, 223, 0.0)' }\n            ])\n          },\n          data: []\n        }]\n      });\n    },\n\n    updateTrendData() {\n      const now = new Date().toLocaleTimeString();\n      const mbps = parseFloat(this.currentMbps);\n\n      this.trendData.times.push(now);\n      this.trendData.mbps.push(mbps);\n\n      // 保持折线图只显示最近 60 秒的数据\n      if (this.trendData.times.length > 60) {\n        this.trendData.times.shift();\n        this.trendData.mbps.shift();\n      }\n\n      this.trendInstance.setOption({\n        xAxis: { data: this.trendData.times },\n        series: [{ data: this.trendData.mbps }]\n      });\n    },\n\n    updateProtocolChart() {\n      const protoCount = {};\n      this.flow.forEach(item => {\n        item.protocols.forEach(p => { \n          protoCount[p] = (protoCount[p] || 0) + item.bytes; // 宏观按流量(Bytes)统计协议占比\n        });\n      });\n      const pieData = Object.keys(protoCount).map(key => ({ name: key, value: protoCount[key] }));\n\n      this.protocolInstance.setOption({\n        title: { text: '全网协议流量占比', textStyle: { color: '#e2e8f0', fontSize: 16 } },\n        tooltip: { trigger: 'item', formatter: '{a} <br/>{b} : {c} Bytes ({d}%)' },\n        series: [{\n          name: '协议分布',\n          type: 'pie',\n          radius: ['50%', '75%'],\n          center: ['50%', '55%'],\n          roseType: 'area', // 玫瑰图效果更具视觉冲击力\n          itemStyle: { borderRadius: 8 },\n          label: { color: '#e2e8f0' },\n          data: pieData\n        }]\n      });\n    },\n\n    resizeCharts() {\n      if (this.trendInstance) this.trendInstance.resize();\n      if (this.protocolInstance) this.protocolInstance.resize();\n    }\n  }\n}\n</script>\n\n<style scoped>\n.dashboard-container { display: flex; flex-direction: column; gap: 20px; height: 100%; }\n\n/* 顶部卡片样式 */\n.stat-cards { display: flex; gap: 20px; }\n.card { flex: 1; background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border-left: 4px solid #38bdf8; }\n.card-title { color: #94a3b8; font-size: 14px; margin-bottom: 10px; }\n.card-value { font-size: 28px; font-weight: bold; font-family: 'Courier New', Courier, monospace; }\n.unit { font-size: 14px; color: #64748b; font-family: sans-serif; }\n.throughput { color: #08ebdf; }\n.pps { color: #38bdf8; }\n.active-ips { color: #a3e635; }\n.protocol { color: #f472b6; }\n\n/* 中间与底部布局 */\n.main-chart-row { height: 300px; display: flex; }\n.bottom-row { display: flex; height: 280px; gap: 20px; }\n.chart-box { background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }\n.full-width { width: 100%; }\n.half-width { flex: 1; }\n\n/* 右下角信息面板 */\n.info-box { background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }\n.info-box h3 { margin-top: 0; color: #e2e8f0; font-size: 16px; margin-bottom: 20px; }\n.status-list { list-style: none; padding: 0; margin: 0; }\n.status-list li { margin-bottom: 15px; display: flex; justify-content: space-between; border-bottom: 1px dashed #334155; padding-bottom: 10px; }\n.status-label { color: #94a3b8; font-size: 14px; }\n.status-value { font-size: 14px; font-weight: bold; color: #cbd5e1; }\n.status-value.safe { color: #22c55e; }\n.status-value.warning { color: #f59e0b; }\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAqB;;EACzBA,KAAK,EAAC;AAAY;;EAChBA,KAAK,EAAC;AAAM;;EAEVA,KAAK,EAAC;AAAuB;;EAI/BA,KAAK,EAAC;AAAM;;EAEVA,KAAK,EAAC;AAAgB;;EAIxBA,KAAK,EAAC;AAAM;;EAEVA,KAAK,EAAC;AAAuB;;EAI/BA,KAAK,EAAC;AAAM;;EAEVA,KAAK,EAAC;AAAqB;;EAM/BA,KAAK,EAAC;AAAgB;;EACpBA,KAAK,EAAC,sBAAsB;EAACC,GAAG,EAAC;;;EAGnCD,KAAK,EAAC;AAAY;;EAChBA,KAAK,EAAC,sBAAsB;EAACC,GAAG,EAAC;;;uBAjC1CC,mBAAA,CAwDM,OAxDNC,UAwDM,GAvDJC,mBAAA,CAyBM,OAzBNC,UAyBM,GAxBJD,mBAAA,CAKM,OALNE,UAKM,G,0BAJJF,mBAAA,CAAqC;IAAhCJ,KAAK,EAAC;EAAY,GAAC,SAAO,qBAC/BI,mBAAA,CAEM,OAFNG,UAEM,G,kCADDC,QAAA,CAAAC,WAAW,IAAG,GAAC,iB,0BAAAL,mBAAA,CAA8B;IAAxBJ,KAAK,EAAC;EAAM,GAAC,MAAI,oB,KAG7CI,mBAAA,CAKM,OALNM,UAKM,G,0BAJJN,mBAAA,CAAqC;IAAhCJ,KAAK,EAAC;EAAY,GAAC,SAAO,qBAC/BI,mBAAA,CAEM,OAFNO,UAEM,G,kCADDH,QAAA,CAAAI,UAAU,IAAG,GAAC,iB,0BAAAR,mBAAA,CAA6B;IAAvBJ,KAAK,EAAC;EAAM,GAAC,KAAG,oB,KAG3CI,mBAAA,CAKM,OALNS,UAKM,G,0BAJJT,mBAAA,CAAsC;IAAjCJ,KAAK,EAAC;EAAY,GAAC,UAAQ,qBAChCI,mBAAA,CAEM,OAFNU,UAEM,G,kCADDN,QAAA,CAAAO,WAAW,IAAG,GAAC,iB,0BAAAX,mBAAA,CAA2B;IAArBJ,KAAK,EAAC;EAAM,GAAC,GAAC,oB,KAG1CI,mBAAA,CAKM,OALNY,UAKM,G,0BAJJZ,mBAAA,CAAoC;IAA/BJ,KAAK,EAAC;EAAY,GAAC,QAAM,qBAC9BI,mBAAA,CAEM,OAFNa,WAEM,EAAAC,gBAAA,CADDV,QAAA,CAAAW,WAAW,iB,KAKpBf,mBAAA,CAEM,OAFNgB,WAEM,GADJhB,mBAAA,CAA+D,OAA/DiB,WAA+D,8B,GAGjEjB,mBAAA,CAuBM,OAvBNkB,WAuBM,GAtBJlB,mBAAA,CAAkE,OAAlEmB,WAAkE,+B","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}
{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  name: 'Dashboard',\n  props: {\n    // 接收 App.vue 传来的秒级实时数据\n    flow: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      trendInstance: null,\n      protocolInstance: null,\n      // 本地维护一个时间序列，用于绘制动态趋势图\n      trendData: {\n        times: [],\n        mbps: []\n      }\n    };\n  },\n  computed: {\n    // 聚合计算：总吞吐量 (Bytes 转 Mbps = Bytes * 8 / 1024 / 1024)\n    currentMbps() {\n      if (!this.flow.length) return '0.00';\n      const totalBytes = this.flow.reduce((sum, item) => sum + item.bytes, 0);\n      return (totalBytes * 8 / 1024 / 1024).toFixed(2);\n    },\n    // 聚合计算：总包数\n    currentPPS() {\n      if (!this.flow.length) return 0;\n      return this.flow.reduce((sum, item) => sum + item.packets, 0);\n    },\n    // 活跃节点数\n    activeNodes() {\n      return this.flow.length;\n    },\n    // 计算出现次数最多的协议\n    topProtocol() {\n      if (!this.flow.length) return 'N/A';\n      const count = {};\n      this.flow.forEach(item => {\n        item.protocols.forEach(p => {\n          count[p] = (count[p] || 0) + 1;\n        });\n      });\n      const sorted = Object.keys(count).sort((a, b) => count[b] - count[a]);\n      return sorted[0] || 'Unknown';\n    }\n  },\n  watch: {\n    // 每次收到新数据，更新趋势图和环形图\n    flow: {\n      handler(newData) {\n        if (newData) {\n          this.updateTrendData();\n          this.updateProtocolChart();\n        }\n      },\n      deep: true\n    }\n  },\n  mounted() {\n    this.initCharts();\n    window.addEventListener('resize', this.resizeCharts);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.resizeCharts);\n    if (this.trendInstance) this.trendInstance.dispose();\n    if (this.protocolInstance) this.protocolInstance.dispose();\n  },\n  methods: {\n    initCharts() {\n      this.trendInstance = echarts.init(this.$refs.globalTrendChart);\n      this.protocolInstance = echarts.init(this.$refs.globalProtocolChart);\n\n      // 初始化趋势图空壳\n      this.trendInstance.setOption({\n        title: {\n          text: '宏观网络吞吐量实时波动 (Mbps)',\n          textStyle: {\n            color: '#e2e8f0',\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: {\n            type: 'cross'\n          }\n        },\n        grid: {\n          left: '3%',\n          right: '4%',\n          bottom: '3%',\n          containLabel: true\n        },\n        xAxis: {\n          type: 'category',\n          boundaryGap: false,\n          data: [],\n          axisLabel: {\n            color: '#94a3b8'\n          }\n        },\n        yAxis: {\n          type: 'value',\n          axisLabel: {\n            color: '#94a3b8'\n          },\n          splitLine: {\n            lineStyle: {\n              color: '#334155'\n            }\n          }\n        },\n        series: [{\n          name: '吞吐量',\n          type: 'line',\n          smooth: true,\n          symbol: 'none',\n          itemStyle: {\n            color: '#08ebdf'\n          },\n          areaStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n              offset: 0,\n              color: 'rgba(8, 235, 223, 0.5)'\n            }, {\n              offset: 1,\n              color: 'rgba(8, 235, 223, 0.0)'\n            }])\n          },\n          data: []\n        }]\n      });\n    },\n    updateTrendData() {\n      const now = new Date().toLocaleTimeString();\n      const mbps = parseFloat(this.currentMbps);\n      this.trendData.times.push(now);\n      this.trendData.mbps.push(mbps);\n\n      // 保持折线图只显示最近 60 秒的数据\n      if (this.trendData.times.length > 60) {\n        this.trendData.times.shift();\n        this.trendData.mbps.shift();\n      }\n      this.trendInstance.setOption({\n        xAxis: {\n          data: this.trendData.times\n        },\n        series: [{\n          data: this.trendData.mbps\n        }]\n      });\n    },\n    updateProtocolChart() {\n      const protoCount = {};\n      this.flow.forEach(item => {\n        item.protocols.forEach(p => {\n          protoCount[p] = (protoCount[p] || 0) + item.bytes; // 宏观按流量(Bytes)统计协议占比\n        });\n      });\n      const pieData = Object.keys(protoCount).map(key => ({\n        name: key,\n        value: protoCount[key]\n      }));\n      this.protocolInstance.setOption({\n        title: {\n          text: '全网协议流量占比',\n          textStyle: {\n            color: '#e2e8f0',\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'item',\n          formatter: '{a} <br/>{b} : {c} Bytes ({d}%)'\n        },\n        series: [{\n          name: '协议分布',\n          type: 'pie',\n          radius: ['50%', '75%'],\n          center: ['50%', '55%'],\n          roseType: 'area',\n          // 玫瑰图效果更具视觉冲击力\n          itemStyle: {\n            borderRadius: 8\n          },\n          label: {\n            color: '#e2e8f0'\n          },\n          data: pieData\n        }]\n      });\n    },\n    resizeCharts() {\n      if (this.trendInstance) this.trendInstance.resize();\n      if (this.protocolInstance) this.protocolInstance.resize();\n    }\n  }\n};","map":{"version":3,"names":["echarts","name","props","flow","type","Array","default","data","trendInstance","protocolInstance","trendData","times","mbps","computed","currentMbps","length","totalBytes","reduce","sum","item","bytes","toFixed","currentPPS","packets","activeNodes","topProtocol","count","forEach","protocols","p","sorted","Object","keys","sort","a","b","watch","handler","newData","updateTrendData","updateProtocolChart","deep","mounted","initCharts","window","addEventListener","resizeCharts","beforeUnmount","removeEventListener","dispose","methods","init","$refs","globalTrendChart","globalProtocolChart","setOption","title","text","textStyle","color","fontSize","tooltip","trigger","axisPointer","grid","left","right","bottom","containLabel","xAxis","boundaryGap","axisLabel","yAxis","splitLine","lineStyle","series","smooth","symbol","itemStyle","areaStyle","graphic","LinearGradient","offset","now","Date","toLocaleTimeString","parseFloat","push","shift","protoCount","pieData","map","key","value","formatter","radius","center","roseType","borderRadius","label","resize"],"sources":["/home/zcz/桌面/smartcampus/frontend/src/components/Dashboard.vue"],"sourcesContent":["<template>\n  <div class=\"dashboard-container\">\n    <div class=\"stat-cards\">\n      <div class=\"card\">\n        <div class=\"card-title\">全网实时吞吐量</div>\n        <div class=\"card-value throughput\">\n          {{ currentMbps }} <span class=\"unit\">Mbps</span>\n        </div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-title\">全网实时包速率</div>\n        <div class=\"card-value pps\">\n          {{ currentPPS }} <span class=\"unit\">PPS</span>\n        </div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-title\">监测活跃大流节点</div>\n        <div class=\"card-value active-ips\">\n          {{ activeNodes }} <span class=\"unit\">个</span>\n        </div>\n      </div>\n      <div class=\"card\">\n        <div class=\"card-title\">当前主要协议</div>\n        <div class=\"card-value protocol\">\n          {{ topProtocol }}\n        </div>\n      </div>\n    </div>\n\n    <div class=\"main-chart-row\">\n      <div class=\"chart-box full-width\" ref=\"globalTrendChart\"></div>\n    </div>\n\n    <div class=\"bottom-row\">\n      <div class=\"chart-box half-width\" ref=\"globalProtocolChart\"></div>\n      <div class=\"info-box half-width\">\n        <h3>全网安全态势感知概览</h3>\n        <ul class=\"status-list\">\n          <li>\n            <span class=\"status-label\">系统运行状态：</span>\n            <span class=\"status-value safe\">正常抓包解析中</span>\n          </li>\n          <li>\n            <span class=\"status-label\">当前链路带宽：</span>\n            <span class=\"status-value\">10 Gbps (监测中)</span>\n          </li>\n          <li>\n            <span class=\"status-label\">异常流量预警：</span>\n            <span class=\"status-value warning\">未检测到明显 DDoS/扫描攻击</span>\n          </li>\n          <li>\n            <span class=\"status-label\">数据接入点：</span>\n            <span class=\"status-value\">核心交换机/出口网关</span>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts';\n\nexport default {\n  name: 'Dashboard',\n  props: {\n    // 接收 App.vue 传来的秒级实时数据\n    flow: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      trendInstance: null,\n      protocolInstance: null,\n      // 本地维护一个时间序列，用于绘制动态趋势图\n      trendData: {\n        times: [],\n        mbps: []\n      }\n    }\n  },\n  computed: {\n    // 聚合计算：总吞吐量 (Bytes 转 Mbps = Bytes * 8 / 1024 / 1024)\n    currentMbps() {\n      if (!this.flow.length) return '0.00';\n      const totalBytes = this.flow.reduce((sum, item) => sum + item.bytes, 0);\n      return (totalBytes * 8 / 1024 / 1024).toFixed(2);\n    },\n    // 聚合计算：总包数\n    currentPPS() {\n      if (!this.flow.length) return 0;\n      return this.flow.reduce((sum, item) => sum + item.packets, 0);\n    },\n    // 活跃节点数\n    activeNodes() {\n      return this.flow.length;\n    },\n    // 计算出现次数最多的协议\n    topProtocol() {\n      if (!this.flow.length) return 'N/A';\n      const count = {};\n      this.flow.forEach(item => {\n        item.protocols.forEach(p => {\n          count[p] = (count[p] || 0) + 1;\n        });\n      });\n      const sorted = Object.keys(count).sort((a, b) => count[b] - count[a]);\n      return sorted[0] || 'Unknown';\n    }\n  },\n  watch: {\n    // 每次收到新数据，更新趋势图和环形图\n    flow: {\n      handler(newData) {\n        if (newData) {\n          this.updateTrendData();\n          this.updateProtocolChart();\n        }\n      },\n      deep: true\n    }\n  },\n  mounted() {\n    this.initCharts();\n    window.addEventListener('resize', this.resizeCharts);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.resizeCharts);\n    if (this.trendInstance) this.trendInstance.dispose();\n    if (this.protocolInstance) this.protocolInstance.dispose();\n  },\n  methods: {\n    initCharts() {\n      this.trendInstance = echarts.init(this.$refs.globalTrendChart);\n      this.protocolInstance = echarts.init(this.$refs.globalProtocolChart);\n      \n      // 初始化趋势图空壳\n      this.trendInstance.setOption({\n        title: { text: '宏观网络吞吐量实时波动 (Mbps)', textStyle: { color: '#e2e8f0', fontSize: 16 } },\n        tooltip: { trigger: 'axis', axisPointer: { type: 'cross' } },\n        grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },\n        xAxis: { type: 'category', boundaryGap: false, data: [], axisLabel: { color: '#94a3b8' } },\n        yAxis: { type: 'value', axisLabel: { color: '#94a3b8' }, splitLine: { lineStyle: { color: '#334155' } } },\n        series: [{\n          name: '吞吐量',\n          type: 'line',\n          smooth: true,\n          symbol: 'none',\n          itemStyle: { color: '#08ebdf' },\n          areaStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [\n              { offset: 0, color: 'rgba(8, 235, 223, 0.5)' },\n              { offset: 1, color: 'rgba(8, 235, 223, 0.0)' }\n            ])\n          },\n          data: []\n        }]\n      });\n    },\n\n    updateTrendData() {\n      const now = new Date().toLocaleTimeString();\n      const mbps = parseFloat(this.currentMbps);\n\n      this.trendData.times.push(now);\n      this.trendData.mbps.push(mbps);\n\n      // 保持折线图只显示最近 60 秒的数据\n      if (this.trendData.times.length > 60) {\n        this.trendData.times.shift();\n        this.trendData.mbps.shift();\n      }\n\n      this.trendInstance.setOption({\n        xAxis: { data: this.trendData.times },\n        series: [{ data: this.trendData.mbps }]\n      });\n    },\n\n    updateProtocolChart() {\n      const protoCount = {};\n      this.flow.forEach(item => {\n        item.protocols.forEach(p => { \n          protoCount[p] = (protoCount[p] || 0) + item.bytes; // 宏观按流量(Bytes)统计协议占比\n        });\n      });\n      const pieData = Object.keys(protoCount).map(key => ({ name: key, value: protoCount[key] }));\n\n      this.protocolInstance.setOption({\n        title: { text: '全网协议流量占比', textStyle: { color: '#e2e8f0', fontSize: 16 } },\n        tooltip: { trigger: 'item', formatter: '{a} <br/>{b} : {c} Bytes ({d}%)' },\n        series: [{\n          name: '协议分布',\n          type: 'pie',\n          radius: ['50%', '75%'],\n          center: ['50%', '55%'],\n          roseType: 'area', // 玫瑰图效果更具视觉冲击力\n          itemStyle: { borderRadius: 8 },\n          label: { color: '#e2e8f0' },\n          data: pieData\n        }]\n      });\n    },\n\n    resizeCharts() {\n      if (this.trendInstance) this.trendInstance.resize();\n      if (this.protocolInstance) this.protocolInstance.resize();\n    }\n  }\n}\n</script>\n\n<style scoped>\n.dashboard-container { display: flex; flex-direction: column; gap: 20px; height: 100%; }\n\n/* 顶部卡片样式 */\n.stat-cards { display: flex; gap: 20px; }\n.card { flex: 1; background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border-left: 4px solid #38bdf8; }\n.card-title { color: #94a3b8; font-size: 14px; margin-bottom: 10px; }\n.card-value { font-size: 28px; font-weight: bold; font-family: 'Courier New', Courier, monospace; }\n.unit { font-size: 14px; color: #64748b; font-family: sans-serif; }\n.throughput { color: #08ebdf; }\n.pps { color: #38bdf8; }\n.active-ips { color: #a3e635; }\n.protocol { color: #f472b6; }\n\n/* 中间与底部布局 */\n.main-chart-row { height: 300px; display: flex; }\n.bottom-row { display: flex; height: 280px; gap: 20px; }\n.chart-box { background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }\n.full-width { width: 100%; }\n.half-width { flex: 1; }\n\n/* 右下角信息面板 */\n.info-box { background: #1e293b; border-radius:
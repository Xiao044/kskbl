{"ast":null,"code":"// 引入对应的6个子组件\nimport Dashboard from './components/Dashboard.vue';\nimport Realtime from './components/Realtime.vue';\nimport History from './components/History.vue';\nimport Rank from './components/Rank.vue';\nimport Alert from './components/Alert.vue';\nimport Chat from './components/Chat.vue';\nexport default {\n  name: 'App',\n  components: {\n    dashboard: Dashboard,\n    realtime: Realtime,\n    history: History,\n    rank: Rank,\n    alert: Alert,\n    chat: Chat\n  },\n  data() {\n    return {\n      current: 'realtime',\n      // 默认展示实时流量页\n      nowTime: '',\n      flow: [],\n      // 当前秒级实时数据\n      history: [],\n      // 历史流数据队列\n      ws: null,\n      menu: [{\n        key: 'dashboard',\n        label: '数据总览'\n      }, {\n        key: 'realtime',\n        label: '实时流量'\n      }, {\n        key: 'history',\n        label: '历史记录'\n      }, {\n        key: 'rank',\n        label: '流量排行'\n      }, {\n        key: 'alert',\n        label: '异常告警'\n      }, {\n        key: 'chat',\n        label: '工作群聊'\n      } // 协同与AI助手入口\n      ]\n    };\n  },\n  computed: {\n    currentComponent() {\n      return this.current;\n    },\n    currentTitle() {\n      const map = {\n        dashboard: '数据总览 - 宏观全景画像',\n        realtime: '实时流量监控 - 秒级微突发感知',\n        history: '历史流记录检索 - 微观取证',\n        rank: '全网大流排行 Top-K',\n        alert: '安全威胁感知与告警',\n        chat: '团队协同与网络运维 AI 助手'\n      };\n      return map[this.current];\n    }\n  },\n  methods: {\n    switchPage(key) {\n      this.current = key;\n    },\n    connectWS() {\n      // 连接后端的流量数据专用通道\n      this.ws = new WebSocket(\"ws://localhost:8000/ws/flow\");\n      this.ws.onmessage = event => {\n        const data = JSON.parse(event.data);\n        this.flow = data;\n\n        // 将最新数据压入历史记录队列，供“历史记录”组件检索\n        data.forEach(item => {\n          this.history.unshift({\n            ...item,\n            time: new Date().toLocaleTimeString()\n          });\n        });\n\n        // 保持历史记录最多保留 100 条，防止浏览器内存溢出\n        if (this.history.length > 100) {\n          this.history = this.history.slice(0, 100);\n        }\n      };\n      this.ws.onclose = () => {\n        console.warn(\"数据通道已断开，2秒后尝试重连...\");\n        setTimeout(() => {\n          this.connectWS();\n        }, 2000);\n      };\n    },\n    updateTime() {\n      this.nowTime = new Date().toLocaleString();\n    }\n  },\n  mounted() {\n    this.connectWS();\n    this.updateTime();\n    setInterval(this.updateTime, 1000);\n  },\n  beforeUnmount() {\n    if (this.ws) {\n      this.ws.close();\n    }\n  }\n};","map":{"version":3,"names":["Dashboard","Realtime","History","Rank","Alert","Chat","name","components","dashboard","realtime","history","rank","alert","chat","data","current","nowTime","flow","ws","menu","key","label","computed","currentComponent","currentTitle","map","methods","switchPage","connectWS","WebSocket","onmessage","event","JSON","parse","forEach","item","unshift","time","Date","toLocaleTimeString","length","slice","onclose","console","warn","setTimeout","updateTime","toLocaleString","mounted","setInterval","beforeUnmount","close"],"sources":["/home/zcz/桌面/smartcampus/frontend/src/App.vue"],"sourcesContent":["<template>\n  <div class=\"app\">\n\n    <div class=\"sidebar\">\n      <h2 class=\"logo\">Net Monitor</h2>\n\n      <div\n        v-for=\"item in menu\"\n        :key=\"item.key\"\n        :class=\"['menu-item', { active: current === item.key }]\"\n        @click=\"switchPage(item.key)\"\n      >\n        {{ item.label }}\n      </div>\n    </div>\n\n    <div class=\"content\">\n\n      <div class=\"topbar\">\n        <div class=\"title\">{{ currentTitle }}</div>\n        <div class=\"time\">{{ nowTime }}</div>\n      </div>\n\n      <div class=\"page\">\n        <keep-alive>\n          <component\n            :is=\"currentComponent\"\n            :flow=\"flow\"\n            :history=\"history\"\n          />\n        </keep-alive>\n      </div>\n\n    </div>\n\n  </div>\n</template>\n\n<script>\n// 引入对应的6个子组件\nimport Dashboard from './components/Dashboard.vue'\nimport Realtime from './components/Realtime.vue'\nimport History from './components/History.vue'\nimport Rank from './components/Rank.vue'\nimport Alert from './components/Alert.vue'\nimport Chat from './components/Chat.vue'\n\nexport default {\n  name: 'App',\n  components: {\n    dashboard: Dashboard,\n    realtime: Realtime,\n    history: History,\n    rank: Rank,\n    alert: Alert,\n    chat: Chat\n  },\n\n  data() {\n    return {\n      current: 'realtime', // 默认展示实时流量页\n      nowTime: '',\n      flow: [],      // 当前秒级实时数据\n      history: [],   // 历史流数据队列\n      ws: null,\n      menu: [\n        { key: 'dashboard', label: '数据总览' },\n        { key: 'realtime', label: '实时流量' },\n        { key: 'history', label: '历史记录' },\n        { key: 'rank', label: '流量排行' },\n        { key: 'alert', label: '异常告警' },\n        { key: 'chat', label: '工作群聊' } // 协同与AI助手入口\n      ]\n    }\n  },\n\n  computed: {\n    currentComponent() {\n      return this.current\n    },\n    currentTitle() {\n      const map = {\n        dashboard: '数据总览 - 宏观全景画像',\n        realtime: '实时流量监控 - 秒级微突发感知',\n        history: '历史流记录检索 - 微观取证',\n        rank: '全网大流排行 Top-K',\n        alert: '安全威胁感知与告警',\n        chat: '团队协同与网络运维 AI 助手'\n      }\n      return map[this.current]\n    }\n  },\n\n  methods: {\n    switchPage(key) {\n      this.current = key\n    },\n\n    connectWS() {\n      // 连接后端的流量数据专用通道\n      this.ws = new WebSocket(\"ws://localhost:8000/ws/flow\")\n\n      this.ws.onmessage = (event) => {\n        const data = JSON.parse(event.data)\n        this.flow = data\n\n        // 将最新数据压入历史记录队列，供“历史记录”组件检索\n        data.forEach(item => {\n          this.history.unshift({\n            ...item,\n            time: new Date().toLocaleTimeString()\n          })\n        })\n\n        // 保持历史记录最多保留 100 条，防止浏览器内存溢出\n        if (this.history.length > 100) {\n          this.history = this.history.slice(0, 100)\n        }\n      }\n\n      this.ws.onclose = () => {\n        console.warn(\"数据通道已断开，2秒后尝试重连...\")\n        setTimeout(() => {\n          this.connectWS()\n        }, 2000)\n      }\n    },\n\n    updateTime() {\n      this.nowTime = new Date().toLocaleString()\n    }\n  },\n\n  mounted() {\n    this.connectWS()\n    this.updateTime()\n    setInterval(this.updateTime, 1000)\n  },\n\n  beforeUnmount() {\n    if (this.ws) {\n      this.ws.close()\n    }\n  }\n}\n</script>\n\n<style scoped>\n/* 全局暗黑科技风基础样式 */\n.app {\n  display: flex;\n  height: 100vh;\n  background: #0f172a;\n  color: #f8fafc;\n  font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n}\n\n/* 左侧边栏 */\n.sidebar {\n  width: 220px;\n  background: #1e293b;\n  padding: 20px 15px;\n  border-right: 1px solid #334155;\n  display: flex;\n  flex-direction: column;\n}\n\n.logo {\n  color: #38bdf8;\n  margin-bottom: 30px;\n  font-size: 22px;\n  font-weight: 800;\n  text-align: center;\n  letter-spacing: 1px;\n}\n\n.menu-item {\n  padding: 12px 16px;\n  margin-bottom: 8px;\n  cursor: pointer;\n  border-radius: 8px;\n  transition: all 0.2s ease;\n  font-size: 15px;\n  font-weight: 500;\n  color: #94a3b8;\n}\n\n.menu-item:hover {\n  background: #334155;\n  color: #e2e8f0;\n}\n\n.menu-item.active {\n  background: #0ea5e9;\n  color: #ffffff;\n  box-shadow: 0 4px 6px -1px rgba(14, 165, 233, 0.3);\n}\n\n/* 右侧内容区 */\n.content {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n}\n\n/* 顶部状态栏 */\n.topbar {\n  height: 60px;\n  background: #1e293b;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0 25px;\n  border-bottom: 1px solid #334155;\n}\n\n.title {\n  font-size: 18px;\n  font-weight: 600;\n  color: #f1f5f9;\n}\n\n.time {\n  color: #64748b;\n  font-size: 14px;\n  font-family: 'Courier New', Courier, monospace;\n}\n\n/* 动态组件容器 */\n.page {\n  flex: 1;\n  padding: 20px;\n  overflow: auto;\n  background: #0f172a;\n}\n</style>"],"mappings":"AAuCA;AACA,OAAOA,SAAQ,MAAO,4BAA2B;AACjD,OAAOC,QAAO,MAAO,2BAA0B;AAC/C,OAAOC,OAAM,MAAO,0BAAyB;AAC7C,OAAOC,IAAG,MAAO,uBAAsB;AACvC,OAAOC,KAAI,MAAO,wBAAuB;AACzC,OAAOC,IAAG,MAAO,uBAAsB;AAEvC,eAAe;EACbC,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IACVC,SAAS,EAAER,SAAS;IACpBS,QAAQ,EAAER,QAAQ;IAClBS,OAAO,EAAER,OAAO;IAChBS,IAAI,EAAER,IAAI;IACVS,KAAK,EAAER,KAAK;IACZS,IAAI,EAAER;EACR,CAAC;EAEDS,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,UAAU;MAAE;MACrBC,OAAO,EAAE,EAAE;MACXC,IAAI,EAAE,EAAE;MAAO;MACfP,OAAO,EAAE,EAAE;MAAI;MACfQ,EAAE,EAAE,IAAI;MACRC,IAAI,EAAE,CACJ;QAAEC,GAAG,EAAE,WAAW;QAAEC,KAAK,EAAE;MAAO,CAAC,EACnC;QAAED,GAAG,EAAE,UAAU;QAAEC,KAAK,EAAE;MAAO,CAAC,EAClC;QAAED,GAAG,EAAE,SAAS;QAAEC,KAAK,EAAE;MAAO,CAAC,EACjC;QAAED,GAAG,EAAE,MAAM;QAAEC,KAAK,EAAE;MAAO,CAAC,EAC9B;QAAED,GAAG,EAAE,OAAO;QAAEC,KAAK,EAAE;MAAO,CAAC,EAC/B;QAAED,GAAG,EAAE,MAAM;QAAEC,KAAK,EAAE;MAAO,EAAE;MAAA;IAEnC;EACF,CAAC;EAEDC,QAAQ,EAAE;IACRC,gBAAgBA,CAAA,EAAG;MACjB,OAAO,IAAI,CAACR,OAAM;IACpB,CAAC;IACDS,YAAYA,CAAA,EAAG;MACb,MAAMC,GAAE,GAAI;QACVjB,SAAS,EAAE,eAAe;QAC1BC,QAAQ,EAAE,kBAAkB;QAC5BC,OAAO,EAAE,gBAAgB;QACzBC,IAAI,EAAE,cAAc;QACpBC,KAAK,EAAE,WAAW;QAClBC,IAAI,EAAE;MACR;MACA,OAAOY,GAAG,CAAC,IAAI,CAACV,OAAO;IACzB;EACF,CAAC;EAEDW,OAAO,EAAE;IACPC,UAAUA,CAACP,GAAG,EAAE;MACd,IAAI,CAACL,OAAM,GAAIK,GAAE;IACnB,CAAC;IAEDQ,SAASA,CAAA,EAAG;MACV;MACA,IAAI,CAACV,EAAC,GAAI,IAAIW,SAAS,CAAC,6BAA6B;MAErD,IAAI,CAACX,EAAE,CAACY,SAAQ,GAAKC,KAAK,IAAK;QAC7B,MAAMjB,IAAG,GAAIkB,IAAI,CAACC,KAAK,CAACF,KAAK,CAACjB,IAAI;QAClC,IAAI,CAACG,IAAG,GAAIH,IAAG;;QAEf;QACAA,IAAI,CAACoB,OAAO,CAACC,IAAG,IAAK;UACnB,IAAI,CAACzB,OAAO,CAAC0B,OAAO,CAAC;YACnB,GAAGD,IAAI;YACPE,IAAI,EAAE,IAAIC,IAAI,CAAC,CAAC,CAACC,kBAAkB,CAAC;UACtC,CAAC;QACH,CAAC;;QAED;QACA,IAAI,IAAI,CAAC7B,OAAO,CAAC8B,MAAK,GAAI,GAAG,EAAE;UAC7B,IAAI,CAAC9B,OAAM,GAAI,IAAI,CAACA,OAAO,CAAC+B,KAAK,CAAC,CAAC,EAAE,GAAG;QAC1C;MACF;MAEA,IAAI,CAACvB,EAAE,CAACwB,OAAM,GAAI,MAAM;QACtBC,OAAO,CAACC,IAAI,CAAC,oBAAoB;QACjCC,UAAU,CAAC,MAAM;UACf,IAAI,CAACjB,SAAS,CAAC;QACjB,CAAC,EAAE,IAAI;MACT;IACF,CA
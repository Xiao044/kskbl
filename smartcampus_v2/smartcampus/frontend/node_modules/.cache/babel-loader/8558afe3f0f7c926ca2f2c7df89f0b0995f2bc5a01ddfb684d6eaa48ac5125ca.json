{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  name: 'Rank',\n  data() {\n    return {\n      topkData: [],\n      chartInstance: null,\n      timer: null\n    };\n  },\n  mounted() {\n    this.chartInstance = echarts.init(this.$refs.rankChart);\n    window.addEventListener('resize', this.resizeChart);\n\n    // 初始化请求，并每 3 秒刷新一次全局排行\n    this.fetchTopK();\n    this.timer = setInterval(this.fetchTopK, 3000);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.resizeChart);\n    if (this.chartInstance) this.chartInstance.dispose();\n    if (this.timer) clearInterval(this.timer);\n  },\n  methods: {\n    async fetchTopK() {\n      try {\n        const res = await fetch('http://localhost:8000/api/topk');\n        const data = await res.json();\n        this.topkData = data.top10;\n        this.updateChart();\n      } catch (err) {\n        console.error(\"无法获取 TopK 数据\", err);\n      }\n    },\n    updateChart() {\n      // 翻转数组，让第一名显示在最上方 (横向柱状图特性)\n      const reversedData = [...this.topkData].reverse();\n      const ips = reversedData.map(d => d.src_ip);\n      const bytes = reversedData.map(d => d.bytes);\n      const option = {\n        title: {\n          text: '全网累计流量风云榜',\n          textStyle: {\n            color: '#e2e8f0',\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis',\n          axisPointer: {\n            type: 'shadow'\n          }\n        },\n        grid: {\n          left: '3%',\n          right: '4%',\n          bottom: '3%',\n          containLabel: true\n        },\n        xAxis: {\n          type: 'value',\n          axisLabel: {\n            color: '#94a3b8'\n          },\n          splitLine: {\n            lineStyle: {\n              color: '#334155'\n            }\n          }\n        },\n        yAxis: {\n          type: 'category',\n          data: ips,\n          axisLabel: {\n            color: '#38bdf8',\n            fontFamily: 'monospace'\n          }\n        },\n        series: [{\n          name: '累计流量(Bytes)',\n          type: 'bar',\n          data: bytes,\n          itemStyle: {\n            color: new echarts.graphic.LinearGradient(1, 0, 0, 0, [{\n              offset: 0,\n              color: '#08ebdf'\n            }, {\n              offset: 1,\n              color: '#0284c7'\n            }]),\n            borderRadius: [0, 4, 4, 0]\n          },\n          label: {\n            show: true,\n            position: 'right',\n            color: '#e2e8f0',\n            formatter: params => this.formatBytes(params.value)\n          }\n        }]\n      };\n      this.chartInstance.setOption(option);\n    },\n    resizeChart() {\n      if (this.chartInstance) this.chartInstance.resize();\n    },\n    formatBytes(bytes) {\n      if (!bytes) return '0 B';\n      const k = 1024;\n      const sizes = ['B', 'KB', 'MB', 'GB'];\n      const i = Math.floor(Math.log(bytes) / Math.log(k));\n      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];\n    }\n  }\n};","map":{"version":3,"names":["echarts","name","data","topkData","chartInstance","timer","mounted","init","$refs","rankChart","window","addEventListener","resizeChart","fetchTopK","setInterval","beforeUnmount","removeEventListener","dispose","clearInterval","methods","res","fetch","json","top10","updateChart","err","console","error","reversedData","reverse","ips","map","d","src_ip","bytes","option","title","text","textStyle","color","fontSize","tooltip","trigger","axisPointer","type","grid","left","right","bottom","containLabel","xAxis","axisLabel","splitLine","lineStyle","yAxis","fontFamily","series","itemStyle","graphic","LinearGradient","offset","borderRadius","label","show","position","formatter","params","formatBytes","value","setOption","resize","k","sizes","i","Math","floor","log","parseFloat","pow","toFixed"],"sources":["/home/zcz/桌面/smartcampus/frontend/src/components/Rank.vue"],"sourcesContent":["<template>\n  <div class=\"rank-container\">\n    <div class=\"chart-box\" ref=\"rankChart\"></div>\n\n    <div class=\"table-box\">\n      <h3>全局流量 Top-K 详细榜单</h3>\n      <table>\n        <thead>\n          <tr>\n            <th>排名</th>\n            <th>源 IP 地址</th>\n            <th>归属地</th>\n            <th>累计消耗流量 (Bytes)</th>\n            <th>累计包数 (Packets)</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr v-for=\"(item, index) in topkData\" :key=\"index\">\n            <td>\n              <span :class=\"['rank-badge', index < 3 ? 'top3' : '']\">{{ index + 1 }}</span>\n            </td>\n            <td class=\"ip-col\">{{ item.src_ip }}</td>\n            <td>{{ item.geo_loc }}</td>\n            <td class=\"bytes-col\">{{ formatBytes(item.bytes) }}</td>\n            <td>{{ item.packets }}</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts';\n\nexport default {\n  name: 'Rank',\n  data() {\n    return {\n      topkData: [],\n      chartInstance: null,\n      timer: null\n    }\n  },\n  mounted() {\n    this.chartInstance = echarts.init(this.$refs.rankChart);\n    window.addEventListener('resize', this.resizeChart);\n    \n    // 初始化请求，并每 3 秒刷新一次全局排行\n    this.fetchTopK();\n    this.timer = setInterval(this.fetchTopK, 3000);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.resizeChart);\n    if (this.chartInstance) this.chartInstance.dispose();\n    if (this.timer) clearInterval(this.timer);\n  },\n  methods: {\n    async fetchTopK() {\n      try {\n        const res = await fetch('http://localhost:8000/api/topk');\n        const data = await res.json();\n        this.topkData = data.top10;\n        this.updateChart();\n      } catch (err) {\n        console.error(\"无法获取 TopK 数据\", err);\n      }\n    },\n    updateChart() {\n      // 翻转数组，让第一名显示在最上方 (横向柱状图特性)\n      const reversedData = [...this.topkData].reverse();\n      const ips = reversedData.map(d => d.src_ip);\n      const bytes = reversedData.map(d => d.bytes);\n\n      const option = {\n        title: { text: '全网累计流量风云榜', textStyle: { color: '#e2e8f0', fontSize: 16 } },\n        tooltip: { trigger: 'axis', axisPointer: { type: 'shadow' } },\n        grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },\n        xAxis: { type: 'value', axisLabel: { color: '#94a3b8' }, splitLine: { lineStyle: { color: '#334155' } } },\n        yAxis: { type: 'category', data: ips, axisLabel: { color: '#38bdf8', fontFamily: 'monospace' } },\n        series: [{\n          name: '累计流量(Bytes)',\n          type: 'bar',\n          data: bytes,\n          itemStyle: {\n            color: new echarts.graphic.LinearGradient(1, 0, 0, 0, [\n              { offset: 0, color: '#08ebdf' },\n              { offset: 1, color: '#0284c7' }\n            ]),\n            borderRadius: [0, 4, 4, 0]\n          },\n          label: { show: true, position: 'right', color: '#e2e8f0', formatter: (params) => this.formatBytes(params.value) }\n        }]\n      };\n      this.chartInstance.setOption(option);\n    },\n    resizeChart() {\n      if (this.chartInstance) this.chartInstance.resize();\n    },\n    formatBytes(bytes) {\n      if (!bytes) return '0 B';\n      const k = 1024;\n      const sizes = ['B', 'KB', 'MB', 'GB'];\n      const i = Math.floor(Math.log(bytes) / Math.log(k));\n      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];\n    }\n  }\n}\n</script>\n\n<style scoped>\n.rank-container { display: flex; gap: 20px; height: 100%; }\n.chart-box { flex: 1.2; background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }\n.table-box { flex: 1; background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); overflow-y: auto; }\n.table-box h3 { margin-top: 0; color: #e2e8f0; font-size: 16px; margin-bottom: 20px; }\ntable { width: 100%; border-collapse: collapse; }\nth, td { padding: 12px; text-align: left; border-bottom: 1px solid #334155; font-size: 14px; }\nth { color: #94a3b8; font-weight: 500; }\n.ip-col { color: #38bdf8; font-family: monospace; }\n.bytes-col { color: #cbd5e1; font-weight: bold; }\n.rank-badge { display: inline-block; width: 24px; height: 24px; line-height: 24px; text-align: center; background: #334155; border-radius: 50%; color: #fff; font-size: 12px; }\n.top3 { background: #f59e0b; color: #fff; box-shadow: 0 0 5px #f59e0b; }\n</style>"],"mappings":"AAiCA,OAAO,KAAKA,OAAM,MAAO,SAAS;AAElC,eAAe;EACbC,IAAI,EAAE,MAAM;EACZC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,EAAE;MACZC,aAAa,EAAE,IAAI;MACnBC,KAAK,EAAE;IACT;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACF,aAAY,GAAIJ,OAAO,CAACO,IAAI,CAAC,IAAI,CAACC,KAAK,CAACC,SAAS,CAAC;IACvDC,MAAM,CAACC,gBAAgB,CAAC,QAAQ,EAAE,IAAI,CAACC,WAAW,CAAC;;IAEnD;IACA,IAAI,CAACC,SAAS,CAAC,CAAC;IAChB,IAAI,CAACR,KAAI,GAAIS,WAAW,CAAC,IAAI,CAACD,SAAS,EAAE,IAAI,CAAC;EAChD,CAAC;EACDE,aAAaA,CAAA,EAAG;IACdL,MAAM,CAACM,mBAAmB,CAAC,QAAQ,EAAE,IAAI,CAACJ,WAAW,CAAC;IACtD,IAAI,IAAI,CAACR,aAAa,EAAE,IAAI,CAACA,aAAa,CAACa,OAAO,CAAC,CAAC;IACpD,IAAI,IAAI,CAACZ,KAAK,EAAEa,aAAa,CAAC,IAAI,CAACb,KAAK,CAAC;EAC3C,CAAC;EACDc,OAAO,EAAE;IACP,MAAMN,SAASA,CAAA,EAAG;MAChB,IAAI;QACF,MAAMO,GAAE,GAAI,MAAMC,KAAK,CAAC,gCAAgC,CAAC;QACzD,MAAMnB,IAAG,GAAI,MAAMkB,GAAG,CAACE,IAAI,CAAC,CAAC;QAC7B,IAAI,CAACnB,QAAO,GAAID,IAAI,CAACqB,KAAK;QAC1B,IAAI,CAACC,WAAW,CAAC,CAAC;MACpB,EAAE,OAAOC,GAAG,EAAE;QACZC,OAAO,CAACC,KAAK,CAAC,cAAc,EAAEF,GAAG,CAAC;MACpC;IACF,CAAC;IACDD,WAAWA,CAAA,EAAG;MACZ;MACA,MAAMI,YAAW,GAAI,CAAC,GAAG,IAAI,CAACzB,QAAQ,CAAC,CAAC0B,OAAO,CAAC,CAAC;MACjD,MAAMC,GAAE,GAAIF,YAAY,CAACG,GAAG,CAACC,CAAA,IAAKA,CAAC,CAACC,MAAM,CAAC;MAC3C,MAAMC,KAAI,GAAIN,YAAY,CAACG,GAAG,CAACC,CAAA,IAAKA,CAAC,CAACE,KAAK,CAAC;MAE5C,MAAMC,MAAK,GAAI;QACbC,KAAK,EAAE;UAAEC,IAAI,EAAE,WAAW;UAAEC,SAAS,EAAE;YAAEC,KAAK,EAAE,SAAS;YAAEC,QAAQ,EAAE;UAAG;QAAE,CAAC;QAC3EC,OAAO,EAAE;UAAEC,OAAO,EAAE,MAAM;UAAEC,WAAW,EAAE;YAAEC,IAAI,EAAE;UAAS;QAAE,CAAC;QAC7DC,IAAI,EAAE;UAA
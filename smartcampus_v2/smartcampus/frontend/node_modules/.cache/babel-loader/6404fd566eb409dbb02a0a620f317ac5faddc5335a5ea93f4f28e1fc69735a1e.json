{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  name: 'Realtime',\n  props: {\n    flow: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      trendInstance: null,\n      protocolInstance: null\n    };\n  },\n  mounted() {\n    this.initCharts();\n    window.addEventListener('resize', this.resizeCharts);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.resizeCharts);\n    if (this.trendInstance) this.trendInstance.dispose();\n    if (this.protocolInstance) this.protocolInstance.dispose();\n  },\n  watch: {\n    flow: {\n      handler(newData) {\n        if (newData && newData.length > 0) {\n          this.updateTrendChart(newData);\n          this.updateProtocolChart(newData);\n        }\n      },\n      deep: true\n    }\n  },\n  methods: {\n    initCharts() {\n      this.trendInstance = echarts.init(this.$refs.trendChart);\n      this.protocolInstance = echarts.init(this.$refs.protocolChart);\n    },\n    updateTrendChart(data) {\n      const ips = data.map(item => item.src_ip);\n      const bytes = data.map(item => item.bytes);\n      const option = {\n        title: {\n          text: '大流吞吐量实时监控 (Top 10)',\n          textStyle: {\n            color: '#e2e8f0',\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'axis'\n        },\n        grid: {\n          left: '3%',\n          right: '4%',\n          bottom: '3%',\n          containLabel: true\n        },\n        xAxis: [{\n          type: 'category',\n          data: ips,\n          axisLabel: {\n            color: '#94a3b8'\n          }\n        }],\n        yAxis: [{\n          type: 'value',\n          name: 'Bytes',\n          axisLabel: {\n            color: '#94a3b8'\n          },\n          splitLine: {\n            lineStyle: {\n              color: '#334155'\n            }\n          }\n        }],\n        series: [{\n          name: '流量',\n          type: 'bar',\n          itemStyle: {\n            color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{\n              offset: 0,\n              color: '#38bdf8'\n            }, {\n              offset: 1,\n              color: '#0284c7'\n            }])\n          },\n          data: bytes\n        }]\n      };\n      this.trendInstance.setOption(option);\n    },\n    updateProtocolChart(data) {\n      const protoCount = {};\n      data.forEach(item => {\n        item.protocols.forEach(p => {\n          protoCount[p] = (protoCount[p] || 0) + item.packets;\n        });\n      });\n      const pieData = Object.keys(protoCount).map(key => ({\n        name: key,\n        value: protoCount[key]\n      }));\n      const option = {\n        title: {\n          text: '协议成分分析',\n          textStyle: {\n            color: '#e2e8f0',\n            fontSize: 16\n          }\n        },\n        tooltip: {\n          trigger: 'item'\n        },\n        series: [{\n          type: 'pie',\n          radius: ['45%', '75%'],\n          avoidLabelOverlap: false,\n          itemStyle: {\n            borderRadius: 5,\n            borderColor: '#1e293b',\n            borderWidth: 2\n          },\n          label: {\n            color: '#e2e8f0'\n          },\n          data: pieData\n        }]\n      };\n      this.protocolInstance.setOption(option);\n    },\n    resizeCharts() {\n      if (this.trendInstance) this.trendInstance.resize();\n      if (this.protocolInstance) this.protocolInstance.resize();\n    },\n    formatBytes(bytes) {\n      if (bytes === 0) return '0 B';\n      const k = 1024;\n      const sizes = ['B', 'KB', 'MB', 'GB'];\n      const i = Math.floor(Math.log(bytes) / Math.log(k));\n      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];\n    }\n  }\n};","map":{"version":3,"names":["echarts","name","props","flow","type","Array","default","data","trendInstance","protocolInstance","mounted","initCharts","window","addEventListener","resizeCharts","beforeUnmount","removeEventListener","dispose","watch","handler","newData","length","updateTrendChart","updateProtocolChart","deep","methods","init","$refs","trendChart","protocolChart","ips","map","item","src_ip","bytes","option","title","text","textStyle","color","fontSize","tooltip","trigger","grid","left","right","bottom","containLabel","xAxis","axisLabel","yAxis","splitLine","lineStyle","series","itemStyle","graphic","LinearGradient","offset","setOption","protoCount","forEach","protocols","p","packets","pieData","Object","keys","key","value","radius","avoidLabelOverlap","borderRadius","borderColor","borderWidth","label","resize","formatBytes","k","sizes","i","Math","floor","log","parseFloat","pow","toFixed"],"sources":["/home/zcz/桌面/smartcampus/frontend/src/components/Realtime.vue"],"sourcesContent":["<template>\n  <div class=\"realtime-container\">\n    <div class=\"charts-row\">\n      <div class=\"chart-box\" ref=\"trendChart\"></div>\n      <div class=\"chart-box\" ref=\"protocolChart\"></div>\n    </div>\n\n    <div class=\"table-box\">\n      <h3 class=\"box-title\">秒级活跃链路监控</h3>\n      <table>\n        <thead>\n          <tr>\n            <th>源 IP 地址</th>\n            <th>流量去向 (地理溯源)</th>\n            <th>瞬时吞吐量</th>\n            <th>数据包量</th>\n            <th>识别应用/协议</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr v-for=\"(item, index) in flow\" :key=\"index\">\n            <td class=\"ip-col\">{{ item.src_ip }}</td>\n            <td class=\"geo-col\">\n              <span :class=\"['status-dot', item.geo_loc.includes('校园网') ? 'dot-safe' : 'dot-warn']\"></span>\n              {{ item.geo_loc }}\n            </td>\n            <td class=\"bytes-col\">{{ formatBytes(item.bytes) }}</td>\n            <td>{{ item.packets }} pps</td>\n            <td>\n              <span class=\"tag\" v-for=\"p in item.protocols\" :key=\"p\">{{ p }}</span>\n            </td>\n          </tr>\n          <tr v-if=\"flow.length === 0\">\n            <td colspan=\"5\" class=\"empty-text\">当前时段无活跃流量</td>\n          </tr>\n        </tbody>\n      </table>\n    </div>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts';\n\nexport default {\n  name: 'Realtime',\n  props: {\n    flow: {\n      type: Array,\n      default: () => []\n    }\n  },\n  data() {\n    return {\n      trendInstance: null,\n      protocolInstance: null\n    }\n  },\n  mounted() {\n    this.initCharts();\n    window.addEventListener('resize', this.resizeCharts);\n  },\n  beforeUnmount() {\n    window.removeEventListener('resize', this.resizeCharts);\n    if (this.trendInstance) this.trendInstance.dispose();\n    if (this.protocolInstance) this.protocolInstance.dispose();\n  },\n  watch: {\n    flow: {\n      handler(newData) {\n        if (newData && newData.length > 0) {\n          this.updateTrendChart(newData);\n          this.updateProtocolChart(newData);\n        }\n      },\n      deep: true\n    }\n  },\n  methods: {\n    initCharts() {\n      this.trendInstance = echarts.init(this.$refs.trendChart);\n      this.protocolInstance = echarts.init(this.$refs.protocolChart);\n    },\n    updateTrendChart(data) {\n      const ips = data.map(item => item.src_ip);\n      const bytes = data.map(item => item.bytes);\n      \n      const option = {\n        title: { text: '大流吞吐量实时监控 (Top 10)', textStyle: { color: '#e2e8f0', fontSize: 16 } },\n        tooltip: { trigger: 'axis' },\n        grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },\n        xAxis: [{ type: 'category', data: ips, axisLabel: { color: '#94a3b8' } }],\n        yAxis: [{ type: 'value', name: 'Bytes', axisLabel: { color: '#94a3b8' }, splitLine: { lineStyle: { color: '#334155' } } }],\n        series: [{ name: '流量', type: 'bar', itemStyle: { color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [{offset: 0, color: '#38bdf8'}, {offset: 1, color: '#0284c7'}]) }, data: bytes }]\n      };\n      this.trendInstance.setOption(option);\n    },\n    updateProtocolChart(data) {\n      const protoCount = {};\n      data.forEach(item => {\n        item.protocols.forEach(p => { protoCount[p] = (protoCount[p] || 0) + item.packets; });\n      });\n      const pieData = Object.keys(protoCount).map(key => ({ name: key, value: protoCount[key] }));\n      \n      const option = {\n        title: { text: '协议成分分析', textStyle: { color: '#e2e8f0', fontSize: 16 } },\n        tooltip: { trigger: 'item' },\n        series: [{ type: 'pie', radius: ['45%', '75%'], avoidLabelOverlap: false, itemStyle: { borderRadius: 5, borderColor: '#1e293b', borderWidth: 2 }, label: { color: '#e2e8f0' }, data: pieData }]\n      };\n      this.protocolInstance.setOption(option);\n    },\n    resizeCharts() {\n      if (this.trendInstance) this.trendInstance.resize();\n      if (this.protocolInstance) this.protocolInstance.resize();\n    },\n    formatBytes(bytes) {\n      if (bytes === 0) return '0 B';\n      const k = 1024;\n      const sizes = ['B', 'KB', 'MB', 'GB'];\n      const i = Math.floor(Math.log(bytes) / Math.log(k));\n      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];\n    }\n  }\n}\n</script>\n\n<style scoped>\n.realtime-container { display: flex; flex-direction: column; gap: 20px; height: 100%; }\n.charts-row { display: flex; height: 350px; gap: 20px; }\n.chart-box { flex: 1; background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }\n.table-box { flex: 1; background: #1e293b; border-radius: 12px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); overflow-y: auto; }\n.box-title { margin-top: 0; margin-bottom: 15px; color: #e2e8f0; font-size: 16px; font-weight: 600; }\ntable { width: 100%; border-collapse: collapse; }\nth, td { padding: 14px 12px; text-align: left; border-bottom: 1px solid #334155; font-size: 14px; }\nth { color: #94a3b8; font-weight: 500; background: #0f172a; position: sticky; top: 0; }\n.ip-col { color: #38bdf8; font-family: 'Courier New', Courier, monospace; font-weight: bold; }\n.bytes-col { color: #cbd5e1; font-weight: 500; }\n.geo-col { display: flex; align-items: center; gap: 8px; }\n.status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }\n.dot-safe { background-color: #22c55e; box-shadow: 0 0 5px #22c55e; }\n.dot-warn { background-color: #f59e0b; box-shadow: 0 0 5px #f59e0b; }\n.tag { display: inline-block; background: #38bdf820; color: #38bdf8; padding: 3px 8px; border-radius: 4px; font-size: 12px; margin-right: 6px; border: 1px solid #38bdf840; }\n.empty-text { text-align: center; color: #64748b; padding: 30px !important; }\n</style>"],"mappings":"AA0CA,OAAO,KAAKA,OAAM,MAAO,SAAS;AAElC,eAAe;EACbC,IAAI,EAAE,UAAU;EAChBC,KAAK,EAAE;IACLC,IAAI,EAAE;MACJC,IAAI,EAAEC,KAAK;MACXC,OAAO,EAAEA,CAAA,KAAM;IACjB;EACF,CAAC;EACDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,aAAa,EAAE,IAAI;MACnBC,gBAAgB,EAAE;IACpB;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,UAAU,CAAC,CAAC;IACjBC,MAAM,CAACC,gBAAgB,CAAC,QAAQ,EAAE,IAAI,CAACC,YAAY,CAAC;EACtD,CAAC;EACDC,aAAaA,CAAA,EAAG;IACdH,MAAM,CAACI,mBAAmB,CAAC,QAAQ,EAAE,IAAI,CAACF,YAAY,CAAC;IACvD,IAAI,IAAI,CAACN,aAAa,EAAE,IAAI,CAACA,aAAa,CAACS,OAAO,CAAC,CAAC;IACpD,IAAI,IAAI,CAACR,gBAAgB,EAAE,IAAI,CAACA,gBAAgB,CAACQ,OAAO,CAAC,CAAC;EAC5D,CAAC;EACDC,KAAK,EAAE;IACLf,IAAI,EAAE;MACJgB,OAAOA,CAACC,OAAO,EAAE;QACf,IAAIA,OAAM,IAAKA,OAAO,CAACC,MAAK,GAAI,CAAC,EAAE;UACjC,IAAI,CAACC,gBAAgB,CAACF,OAAO,CAAC;UAC9B,IAAI,CAACG,mBAAmB,CAACH,OAAO,CAAC;QACnC;MACF,CAAC;MACDI,IAAI,EAAE;IACR;EACF,CAAC;EACDC,OAAO,EAAE;IACPd,UAAUA,CAAA,EAAG;MACX,IAAI,CAACH,aAAY,GAAIR,OAAO,CAAC0B,IAAI,CAAC,IAAI,CAACC,KAAK,CAACC,UAAU,CAAC;MACxD,IAAI,CAACnB,gBAAe,GAAIT,OAAO,CAAC0B,IAAI,CAAC,IAAI,CAACC,KAAK,CAACE,aAAa,CAAC;IAChE,CAAC;IACDP,gBAAgBA,CAACf,IAAI,EAAE;MACrB,MAAMuB,GAAE,GAAIvB,IAAI,CAACwB,GAAG,CAACC,IAAG,IAAKA,IAAI,CAACC,MAAM,CAAC;MACzC,MAAMC,KAAI,GAAI3B,IAAI,CAACwB,GAAG,CAACC,IAAG,IAAKA,IAAI,CAACE,KAAK,CAAC;MAE1C,MAAMC,MAAK,GAAI;QACbC,KAAK,EAAE;UAAEC,IAAI,EAAE,oBAAoB;UAAEC,SAAS,EAAE;YAAEC,KAAK,EAAE,SAAS;Y
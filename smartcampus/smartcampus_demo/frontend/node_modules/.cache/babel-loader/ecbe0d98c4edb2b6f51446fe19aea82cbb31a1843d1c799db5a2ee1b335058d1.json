{"ast":null,"code":"import * as echarts from 'echarts';\nexport default {\n  props: ['flow'],\n  data() {\n    return {\n      history: [],\n      chart: null,\n      timeData: [],\n      totalData: []\n    };\n  },\n  watch: {\n    flow: {\n      handler(val) {\n        this.addRecord(val);\n      },\n      deep: true\n    }\n  },\n  methods: {\n    addRecord(flow) {\n      if (!flow || flow.length === 0) return;\n      const total = flow.reduce((sum, i) => sum + (i.bytes || 0), 0);\n      const time = new Date().toLocaleTimeString();\n      const record = {\n        time,\n        total,\n        count: flow.length\n      };\n      this.history.push(record);\n      this.timeData.push(time);\n      this.totalData.push(total);\n\n      // 限制历史长度（避免内存无限增长）\n      if (this.history.length > 50) {\n        this.history.shift();\n        this.timeData.shift();\n        this.totalData.shift();\n      }\n      this.updateChart();\n    },\n    initChart() {\n      const dom = document.getElementById('historyChart');\n      if (!dom) return;\n      this.chart = echarts.init(dom);\n      this.chart.setOption({\n        tooltip: {\n          trigger: 'axis'\n        },\n        xAxis: {\n          type: 'category',\n          data: this.timeData\n        },\n        yAxis: {\n          type: 'value'\n        },\n        series: [{\n          name: '总流量',\n          type: 'line',\n          smooth: true,\n          data: this.totalData,\n          areaStyle: {}\n        }]\n      });\n    },\n    updateChart() {\n      if (!this.chart) return;\n      this.chart.setOption({\n        xAxis: {\n          data: this.timeData\n        },\n        series: [{\n          data: this.totalData\n        }]\n      });\n    }\n  },\n  mounted() {\n    this.$nextTick(() => {\n      this.initChart();\n    });\n  }\n};","map":{"version":3,"names":["echarts","props","data","history","chart","timeData","totalData","watch","flow","handler","val","addRecord","deep","methods","length","total","reduce","sum","i","bytes","time","Date","toLocaleTimeString","record","count","push","shift","updateChart","initChart","dom","document","getElementById","init","setOption","tooltip","trigger","xAxis","type","yAxis","series","name","smooth","areaStyle","mounted","$nextTick"],"sources":["/home/xiao/ppyy/mian/smartcampus/smartcampus_demo/frontend/src/components/History.vue"],"sourcesContent":["<template>\n  <div class=\"history\">\n    <h2>📜 历史流量记录</h2>\n\n    <!-- 折线图 -->\n    <div id=\"historyChart\" class=\"chart\"></div>\n\n    <!-- 历史表格 -->\n    <div class=\"table\">\n      <div class=\"row header\">\n        <div>时间</div>\n        <div>总流量</div>\n        <div>IP数量</div>\n      </div>\n\n      <div class=\"row\" v-for=\"(item, index) in history\" :key=\"index\">\n        <div>{{ item.time }}</div>\n        <div>{{ item.total }}</div>\n        <div>{{ item.count }}</div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport * as echarts from 'echarts'\n\nexport default {\n  props: ['flow'],\n\n  data() {\n    return {\n      history: [],\n      chart: null,\n      timeData: [],\n      totalData: []\n    }\n  },\n\n  watch: {\n    flow: {\n      handler(val) {\n        this.addRecord(val)\n      },\n      deep: true\n    }\n  },\n\n  methods: {\n    addRecord(flow) {\n      if (!flow || flow.length === 0) return\n\n      const total = flow.reduce((sum, i) => sum + (i.bytes || 0), 0)\n      const time = new Date().toLocaleTimeString()\n\n      const record = {\n        time,\n        total,\n        count: flow.length\n      }\n\n      this.history.push(record)\n      this.timeData.push(time)\n      this.totalData.push(total)\n\n      // 限制历史长度（避免内存无限增长）\n      if (this.history.length > 50) {\n        this.history.shift()\n        this.timeData.shift()\n        this.totalData.shift()\n      }\n\n      this.updateChart()\n    },\n\n    initChart() {\n      const dom = document.getElementById('historyChart')\n      if (!dom) return\n\n      this.chart = echarts.init(dom)\n\n      this.chart.setOption({\n        tooltip: { trigger: 'axis' },\n        xAxis: {\n          type: 'category',\n          data: this.timeData\n        },\n        yAxis: {\n          type: 'value'\n        },\n        series: [\n          {\n            name: '总流量',\n            type: 'line',\n            smooth: true,\n            data: this.totalData,\n            areaStyle: {}\n          }\n        ]\n      })\n    },\n\n    updateChart() {\n      if (!this.chart) return\n\n      this.chart.setOption({\n        xAxis: {\n          data: this.timeData\n        },\n        series: [\n          {\n            data: this.totalData\n          }\n        ]\n      })\n    }\n  },\n\n  mounted() {\n    this.$nextTick(() => {\n      this.initChart()\n    })\n  }\n}\n</script>\n\n<style scoped>\n.history {\n  padding: 10px;\n}\n\n.chart {\n  width: 100%;\n  height: 300px;\n  background: #020617;\n  border-radius: 10px;\n  margin-bottom: 20px;\n}\n\n.table {\n  background: #0f172a;\n  border-radius: 10px;\n  overflow: hidden;\n}\n\n.row {\n  display: grid;\n  grid-template-columns: 1fr 1fr 1fr;\n  padding: 10px;\n  border-bottom: 1px solid #1e293b;\n}\n\n.row.header {\n  font-weight: bold;\n  background: #020617;\n}\n</style>\n"],"mappings":"AAyBA,OAAO,KAAKA,OAAM,MAAO,SAAQ;AAEjC,eAAe;EACbC,KAAK,EAAE,CAAC,MAAM,CAAC;EAEfC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,EAAE;MACXC,KAAK,EAAE,IAAI;MACXC,QAAQ,EAAE,EAAE;MACZC,SAAS,EAAE;IACb;EACF,CAAC;EAEDC,KAAK,EAAE;IACLC,IAAI,EAAE;MACJC,OAAOA,CAACC,GAAG,EAAE;QACX,IAAI,CAACC,SAAS,CAACD,GAAG;MACpB,CAAC;MACDE,IAAI,EAAE;IACR;EACF,CAAC;EAEDC,OAAO,EAAE;IACPF,SAASA,CAACH,IAAI,EAAE;MACd,IAAI,CAACA,IAAG,IAAKA,IAAI,CAACM,MAAK,KAAM,CAAC,EAAE;MAEhC,MAAMC,KAAI,GAAIP,IAAI,CAACQ,MAAM,CAAC,CAACC,GAAG,EAAEC,CAAC,KAAKD,GAAE,IAAKC,CAAC,CAACC,KAAI,IAAK,CAAC,CAAC,EAAE,CAAC;MAC7D,MAAMC,IAAG,GAAI,IAAIC,IAAI,CAAC,CAAC,CAACC,kBAAkB,CAAC;MAE3C,MAAMC,MAAK,GAAI;QACbH,IAAI;QACJL,KAAK;QACLS,KAAK,EAAEhB,IAAI,CAACM;MACd;MAEA,IAAI,CAACX,OAAO,CAACs
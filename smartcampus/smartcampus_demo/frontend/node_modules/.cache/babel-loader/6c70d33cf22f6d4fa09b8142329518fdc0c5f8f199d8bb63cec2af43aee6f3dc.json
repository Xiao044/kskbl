{"ast":null,"code":"export default {\n  props: ['realtimeFlow'],\n  data() {\n    return {\n      alerts: [],\n      seenKeys: new Set() // 用于去重\n    };\n  },\n  computed: {\n    latestIp() {\n      if (this.alerts.length === 0) return '-';\n      return this.alerts[this.alerts.length - 1].src_ip;\n    }\n  },\n  watch: {\n    realtimeFlow: {\n      handler(val) {\n        this.checkAlerts(val);\n      },\n      deep: true\n    }\n  },\n  methods: {\n    checkAlerts(flow) {\n      if (!flow) return;\n      flow.forEach(item => {\n        // 阈值判断（可调整）\n        if (item.bytes > 800) {\n          const key = item.src_ip + '_' + item.bytes;\n\n          // 去重，避免重复告警\n          if (!this.seenKeys.has(key)) {\n            this.seenKeys.add(key);\n            this.alerts.push({\n              time: new Date().toLocaleTimeString(),\n              src_ip: item.src_ip,\n              bytes: item.bytes\n            });\n\n            // 限制告警数量\n            if (this.alerts.length > 50) {\n              this.alerts.shift();\n            }\n          }\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["props","data","alerts","seenKeys","Set","computed","latestIp","length","src_ip","watch","realtimeFlow","handler","val","checkAlerts","deep","methods","flow","forEach","item","bytes","key","has","add","push","time","Date","toLocaleTimeString","shift"],"sources":["/home/xiao/ppyy/mian/smartcampus/smartcampus_demo/frontend/src/components/Alert.vue"],"sourcesContent":["<template>\n  <div class=\"alert\">\n    <h2>🚨 异常告警中心</h2>\n\n    <!-- 告警统计 -->\n    <div class=\"stats\">\n      <div class=\"card\">\n        <div class=\"title\">当前告警数</div>\n        <div class=\"value\">{{ alerts.length }}</div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"title\">最近告警IP</div>\n        <div class=\"value\">{{ latestIp }}</div>\n      </div>\n    </div>\n\n    <!-- 告警列表 -->\n    <div class=\"table\">\n      <div class=\"row header\">\n        <div>时间</div>\n        <div>IP</div>\n        <div>流量(bytes)</div>\n        <div>状态</div>\n      </div>\n\n      <div\n        class=\"row\"\n        v-for=\"(item, index) in alerts\"\n        :key=\"index\"\n        :class=\"{ new: index === alerts.length - 1 }\"\n      >\n        <div>{{ item.time }}</div>\n        <div>{{ item.src_ip }}</div>\n        <div>{{ item.bytes }}</div>\n        <div class=\"danger\">⚠ 异常</div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  props: ['realtimeFlow'],\n\n  data() {\n    return {\n      alerts: [],\n      seenKeys: new Set() // 用于去重\n    }\n  },\n\n  computed: {\n    latestIp() {\n      if (this.alerts.length === 0) return '-'\n      return this.alerts[this.alerts.length - 1].src_ip\n    }\n  },\n\n  watch: {\n    realtimeFlow: {\n      handler(val) {\n        this.checkAlerts(val)\n      },\n      deep: true\n    }\n  },\n\n  methods: {\n    checkAlerts(flow) {\n      if (!flow) return\n\n      flow.forEach(item => {\n        // 阈值判断（可调整）\n        if (item.bytes > 800) {\n          const key = item.src_ip + '_' + item.bytes\n\n          // 去重，避免重复告警\n          if (!this.seenKeys.has(key)) {\n            this.seenKeys.add(key)\n\n            this.alerts.push({\n              time: new Date().toLocaleTimeString(),\n              src_ip: item.src_ip,\n              bytes: item.bytes\n            })\n\n            // 限制告警数量\n            if (this.alerts.length > 50) {\n              this.alerts.shift()\n            }\n          }\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.alert {\n  padding: 10px;\n}\n\n.stats {\n  display: flex;\n  gap: 15px;\n  margin-bottom: 20px;\n}\n\n.card {\n  flex: 1;\n  background: #0f172a;\n  padding: 15px;\n  border-radius: 10px;\n  text-align: center;\n}\n\n.title {\n  font-size: 14px;\n  color: #94a3b8;\n}\n\n.value {\n  font-size: 22px;\n  margin-top: 8px;\n  color: #ef4444;\n}\n\n.table {\n  background: #020617;\n  border-radius: 10px;\n  overflow: hidden;\n}\n\n.row {\n  display: grid;\n  grid-template-columns: 1fr 1fr 1fr 1fr;\n  padding: 10px;\n  border-bottom: 1px solid #1e293b;\n}\n\n.row.header {\n  background: #0f172a;\n  font-weight: bold;\n}\n\n.danger {\n  color: #ef4444;\n}\n\n.new {\n  background: rgba(239, 68, 68, 0.15);\n}\n</style>\n"],"mappings":"AA0CA,eAAe;EACbA,KAAK,EAAE,CAAC,cAAc,CAAC;EAEvBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,MAAM,EAAE,EAAE;MACVC,QAAQ,EAAE,IAAIC,GAAG,CAAC,EAAE;IACtB;EACF,CAAC;EAEDC,QAAQ,EAAE;IACRC,QAAQA,CAAA,EAAG;MACT,IAAI,IAAI,CAACJ,MAAM,CAACK,MAAK,KAAM,CAAC,EAAE,OAAO,GAAE;MACvC,OAAO,IAAI,CAACL,MAAM,CAAC,IAAI,CAACA,MAAM,CAACK,MAAK,GAAI,CAAC,CAAC,CAACC,MAAK;IAClD;EACF,CAAC;EAEDC,KAAK,EAAE;IACLC,YAAY,EAAE;MACZC,OAAOA,CAACC,GAAG,EAAE;QACX,IAAI,CAACC,WAAW,CAACD,GAAG;MACtB,CAAC;MACDE,IAAI,EAAE;IACR;EACF,CAAC;EAEDC,OAAO,EAAE;IACPF,WAAWA,CAACG,IAAI,EAAE;MAChB,IAAI,CAACA,IAAI,EAAE;MAEXA,IAAI,CAACC,OAAO,CAACC,IAAG,IAAK;QACnB;QACA,IAAIA,IAAI,CAACC,KAAI,GAAI,GAAG,EAAE;UACpB,MAAMC,GAAE,GAAIF,IAAI,CAACV,MAAK,GAAI,GAAE,GAAIU,IAAI,CAACC,KAAI;;UAEzC;UACA,IAAI,CAAC,IAAI,CAAChB,QAAQ,CAACkB,GAAG,CAACD,GAAG,CAAC,EAAE;YAC3B,IAAI,CAACjB,QAAQ,CAACmB,GAAG,CAACF,GAAG;YAErB,IAAI,CAAClB,MAAM,CAACqB,IAAI,CAAC;cACfC,IAAI,EAAE,IAAIC,IAAI,CAAC,CAAC,CAACC,kBAAkB,CAAC,CAAC;cACrClB,MAAM,EAAEU,IAAI,CAACV,MAAM;cACnBW,KAAK,EAAED,IAAI,CAACC;YACd,CAAC;;YAED;YACA,IAAI,IAAI,CAACjB,MAAM,CAACK,MAAK,GAAI,EAAE,EAAE;cAC3B,IAAI,CAACL,MAAM,CAACyB,KAAK,CAAC;YACpB;UACF;QACF;MACF,CAAC;IACH;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}